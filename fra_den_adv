# 9.  MBAPPE PASSES & SHOTS
# ════════════════════════════════════════════════════════════
def plot_mbappe_passes_shots(df):
    print("Mbappe passes and shots...")
 
    mbappe_passes = df[
        (df["passer"] == "Kylian Mbappé") &
        (df["possEventType"] == "PA") &
        df["ball_x"].notna() &
        df["passOutcome"].notna()
    ].copy()
 
    mbappe_shots = df[
        (df["shooter"] == "Kylian Mbappé") &
        df["ball_x"].notna()
    ].copy()
 
    if mbappe_passes.empty and mbappe_shots.empty:
        print("  No Mbappe pass/shot data found.")
        return
 
    fig, axes = plt.subplots(1, 2, figsize=(22, 8), facecolor="#1a1a1a")
 
    ax = axes[0]
    draw_pitch(ax)
    completed  = mbappe_passes[mbappe_passes["passOutcome"] == "C"]
    incomplete = mbappe_passes[mbappe_passes["passOutcome"] != "C"]
    ax.scatter(completed["ball_x"], completed["ball_y"],
               c="#44ff44", s=100, alpha=0.85, zorder=4,
               edgecolors="#333", linewidths=0.5,
               label=f"Completed (n={len(completed)})")
    ax.scatter(incomplete["ball_x"], incomplete["ball_y"],
               c="#ff4444", s=100, alpha=0.85, zorder=4,
               edgecolors="#333", linewidths=0.5, marker="X",
               label=f"Incomplete (n={len(incomplete)})")
    for _, row in mbappe_passes.iterrows():
        if pd.notna(row["passType"]) and row["passType"] != "S":
            ax.text(row["ball_x"], row["ball_y"] + 2,
                    row["passType"], ha="center", fontsize=7,
                    color="white", alpha=0.7)
    total_passes = len(mbappe_passes)
    comp_pct = 100 * len(completed) // max(total_passes, 1)
    ax.legend(facecolor="#333", labelcolor="white", fontsize=9,
              loc="upper left", framealpha=0.8)
    ax.set_title(f"Mbappé — Pass Map\n({total_passes} passes | {comp_pct}% completion)",
                 color="white", fontsize=12, weight="bold", pad=8)
 
    ax2 = axes[1]
    draw_pitch(ax2)
    SHOT_COLORS = {
        "G": ("#44ff44", "Goal"),
        "S": ("#ffaa00", "Saved"),
        "B": ("#4488ff", "Blocked"),
        "O": ("#ff4444", "Off Target"),
        "F": ("#ff4444", "Off Target"),
        "C": ("#ffaa00", "Saved"),
    }
    SHOT_MARKERS = {"G": "*", "S": "o", "B": "o", "O": "X", "F": "X", "C": "o"}
    shot_patches   = []
    plotted_labels = set()
    for outcome, (col, label) in SHOT_COLORS.items():
        sub = mbappe_shots[mbappe_shots["shotOutcome"] == outcome]
        if sub.empty:
            continue
        ax2.scatter(sub["ball_x"], sub["ball_y"], c=col,
                    s=300 if outcome == "G" else 150,
                    marker=SHOT_MARKERS[outcome], alpha=0.9, zorder=4,
                    edgecolors="white" if outcome == "G" else "#333",
                    linewidths=1.5 if outcome == "G" else 0.5)
        if label not in plotted_labels:
            shot_patches.append(mpatches.Patch(color=col, label=f"{label} (n={len(sub)})"))
            plotted_labels.add(label)
    for _, row in mbappe_shots.iterrows():
        shot_type   = row["shotType"]   if pd.notna(row["shotType"])   else ""
        shot_nature = row["shotNature"] if pd.notna(row["shotNature"]) else ""
        type_label   = {"V": "Volley", "F": "Side Foot", "S": "Standard"}.get(shot_type, shot_type)
        nature_label = {"P": "Power", "A": "Accurate", "F": "Flick"}.get(shot_nature, shot_nature)
        ax2.text(row["ball_x"], row["ball_y"] + 2,
                 f"{row['formattedClock']}\n{type_label} | {nature_label}",
                 ha="center", fontsize=7, color="white", alpha=0.85,
                 bbox=dict(facecolor="#1a1a1a", edgecolor="none", alpha=0.5, pad=1))
    n_goals = len(mbappe_shots[mbappe_shots["shotOutcome"] == "G"])
    ax2.legend(handles=shot_patches, facecolor="#333", labelcolor="white",
               fontsize=9, loc="upper left", framealpha=0.8)
    ax2.set_title(f"Mbappé — Shots\n({len(mbappe_shots)} shots | {n_goals} goal)",
                  color="white", fontsize=12, weight="bold", pad=8)
    ax2.text(0.98, 0.05,
             f"Volley: {len(mbappe_shots[mbappe_shots['shotType'] == 'V'])}\n"
             f"Standard: {len(mbappe_shots[mbappe_shots['shotType'] == 'S'])}\n"
             f"Power: {len(mbappe_shots[mbappe_shots['shotNature'] == 'P'])}\n"
             f"Accurate: {len(mbappe_shots[mbappe_shots['shotNature'] == 'A'])}",
             transform=ax2.transAxes, ha="right", va="bottom", color="#cccccc", fontsize=9,
             bbox=dict(facecolor="#333", edgecolor="#555", alpha=0.8, pad=5))
 
    fig.suptitle("Mbappé — Passes & Shots — FRA vs DEN (WC MD2 2022)",
                 color="white", fontsize=14, weight="bold", y=1.01)
    plt.tight_layout()
    out = f"{OUT_DIR}/mbappe_passes_shots.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
