        bg_col = "#222222" if ri % 2 == 0 else "#1a1a1a"
        ax_tbl.add_patch(plt.Rectangle(
            (0, y - row_h * 0.85), 1, row_h * 0.92,
            transform=ax_tbl.transAxes,
            facecolor=bg_col, edgecolor="none", zorder=0,
        ))
 
        for ci, (val, x) in enumerate(zip(row_vals, xs)):
            is_result = (ci == n_cols - 1)
            ax_tbl.text(x, y, val,
                        transform=ax_tbl.transAxes,
