# 13. DEFENSIVE SHAPE & COMPACTNESS
# ════════════════════════════════════════════════════════════
def plot_defensive_shape(df):
    print("Defensive shape analysis...")
 
    # When the opponent has the ball, measure France's defensive structure
    # from player tracking coordinates
    den_poss = df[
        (df["homeTeam"] == False) &
        (df["possEventType"].notna())
    ].copy()
 
    shape_records = []
    for _, row in den_poss.iterrows():
        period = row.get("period")
        clock  = row.get("startGameClock") or 0
        hp     = row.get("_home_players") or {}
 
        xs = []
        for jersey, p in hp.items():
            if str(jersey) == "1":
                continue  # skip keeper
            px = p.get("x")
            if px is not None:
                if str(period) == "2":
                    px = -px
                xs.append(px)
 
        if len(xs) < 8:
            continue
 
        xs_sorted = sorted(xs)
        def_line    = sum(xs_sorted[:4])  / 4
        mid_line    = sum(xs_sorted[4:8]) / 4
        compactness = mid_line - def_line
        team_width  = xs_sorted[-1] - xs_sorted[0]
 
        shape_records.append({
            'clock':       clock,
            'period':      str(period),
            'def_line':    def_line,
            'mid_line':    mid_line,
            'compactness': compactness,
            'team_width':  team_width,
        })
 
    if not shape_records:
        print("  No shape data found.")
        return
 
    import numpy as np
    clocks      = [r['clock'] for r in shape_records]
    def_lines   = [r['def_line'] for r in shape_records]
    mid_lines   = [r['mid_line'] for r in shape_records]
    compacts    = [r['compactness'] for r in shape_records]
 
    # Smooth with rolling average
    def smooth(vals, w=20):
        return np.convolve(vals, np.ones(w)/w, mode='valid')
 
    clocks_sm   = clocks[10:-9]
    def_sm      = smooth(def_lines)
    mid_sm      = smooth(mid_lines)
    comp_sm     = smooth(compacts)
 
    # Convert clocks to minutes
    mins_sm = [c/60 for c in clocks_sm]
 
    fig, axes = plt.subplots(3, 1, figsize=(20, 14), facecolor="#1a1a1a",
                             sharex=True)
    fig.subplots_adjust(hspace=0.12, left=0.08, right=0.97,
                        top=0.92, bottom=0.06)
 
    # Half-time divider helper
    def add_halftime(ax):
        ax.axvline(45, color="#888888", lw=1.2, ls="--", alpha=0.6)
        ax.text(45.5, ax.get_ylim()[1]*0.97, "HT",
                color="#888888", fontsize=8, va="top")
        ax.axvline(90, color="#888888", lw=1.2, ls="--", alpha=0.6)
        ax.text(90.5, ax.get_ylim()[1]*0.97, "FT",
                color="#888888", fontsize=8, va="top")
 
    def style_ax(ax, ylabel, title):
        ax.set_facecolor("#1a1a1a")
        ax.set_ylabel(ylabel, color="white", fontsize=9)
        ax.set_title(title, color="white", fontsize=10, weight="bold", pad=4)
        ax.tick_params(colors="white")
        for spine in ax.spines.values():
            spine.set_edgecolor("#555")
 
    # ── Plot 1: Defensive line height ─────────────────────────────────────────
    axes[0].fill_between(mins_sm, def_sm, alpha=0.25, color="#4488ff")
    axes[0].plot(mins_sm, def_sm, color="#4488ff", lw=1.8, label="Def line (avg x)")
    axes[0].fill_between(mins_sm, mid_sm, alpha=0.15, color="#ffaa00")
    axes[0].plot(mins_sm, mid_sm, color="#ffaa00", lw=1.8, label="Mid line (avg x)")
    axes[0].axhline(0, color="white", lw=0.8, ls=":", alpha=0.4)
    axes[0].text(1, 1, "← France own half  |  Opp half →",
                 transform=axes[0].transAxes, ha="right", va="top",
                 color="#aaaaaa", fontsize=7.5)
    axes[0].legend(facecolor="#333", labelcolor="white", fontsize=8, loc="upper left")
    style_ax(axes[0], "Avg x position (m)", "France Defensive & Midfield Line Height (when Opponent in possession)")
    add_halftime(axes[0])
 
    # ── Plot 2: Compactness ────────────────────────────────────────────────────
    axes[1].fill_between(mins_sm, comp_sm, alpha=0.25, color="#44ff44")
    axes[1].plot(mins_sm, comp_sm, color="#44ff44", lw=1.8)
    avg_comp = sum(compacts) / len(compacts)
    axes[1].axhline(avg_comp, color="#ffff00", lw=1, ls="--", alpha=0.7,
                    label=f"Match avg: {avg_comp:.1f}m")
    axes[1].legend(facecolor="#333", labelcolor="white", fontsize=8)
    style_ax(axes[1], "Gap (m)", "Compactness — Gap Between Defensive & Midfield Lines\n(smaller = more compact, harder to play through)")
    add_halftime(axes[1])
 
    # ── Plot 3: Goals and key events overlay ──────────────────────────────────
    axes[2].fill_between(mins_sm, comp_sm, alpha=0.15, color="#44ff44")
    axes[2].plot(mins_sm, comp_sm, color="#44ff44", lw=1.5, alpha=0.6)
 
    # Mark goals and opportunities
    goal_events = df[df["shotOutcome"] == "G"].copy()
    opp_events  = df[df["opportunityType"].isin(["C","H"])].copy()
 
    for _, g in goal_events.iterrows():
        gc = (g.get("startGameClock") or 0) / 60
        is_fra = g["homeTeam"]
        axes[2].axvline(gc, color="#00ee44" if is_fra else "#ff4444",
                        lw=2, alpha=0.9, zorder=5)
        axes[2].text(gc + 0.3, avg_comp + 1,
                     f"GOAL\n{(g.get('shooter') or '').split()[-1]}",
                     color="#00ee44" if is_fra else "#ff4444",
                     fontsize=7, weight="bold")
 
    style_ax(axes[2], "Compactness (m)",
             "Compactness Over Time with Goals Marked")
    axes[2].set_xlabel("Match Minute", color="white", fontsize=9)
    add_halftime(axes[2])
 
    # Summary stats box
    axes[0].text(0.99, 0.05,
                 f"Avg def line: {sum(def_lines)/len(def_lines):.1f}m\n"
                 f"Avg compactness: {avg_comp:.1f}m\n"
                 f"Min compactness: {min(compacts):.1f}m\n"
                 f"Max compactness: {max(compacts):.1f}m",
                 transform=axes[0].transAxes, ha="right", va="bottom",
                 color="#cccccc", fontsize=8,
                 bbox=dict(facecolor="#222", edgecolor="#555", alpha=0.85, pad=5))
 
    fig.suptitle("France Defensive Shape — FRA vs DEN  |  WC 2022 MD2\n"
                 "Measured when Opponent in possession  |  Rolling 20-event average",
                 color="white", fontsize=13, weight="bold", y=0.975)
 
    out = f"{OUT_DIR}/defensive_shape.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
 
