def draw_pitch(ax, length=105, width=68, line_color="white",
               bg="#2d5c2d", lw=1.5, attack_label="France attack →"):
    ax.set_facecolor(bg)
    ax.set_xlim(-length/2 - 3, length/2 + 3)
    ax.set_ylim(-width/2 - 3, width/2 + 3)
    ax.set_aspect("equal")
    ax.axis("off")
 
    kw = dict(edgecolor=line_color, fill=False, linewidth=lw)
    ax.add_patch(Rectangle((-length/2, -width/2), length, width, **kw))
    ax.plot([0, 0], [-width/2, width/2], color=line_color, lw=lw)
    ax.add_patch(plt.Circle((0, 0), 9.15, **kw))
    ax.plot(0, 0, "o", color=line_color, ms=2)
 
    for side in [-1, 1]:
        xp = side * length / 2
        ax.add_patch(Rectangle((xp - side*16.5, -20.15), side*16.5, 40.3, **kw))
        ax.add_patch(Rectangle((xp - side*5.5,  -9.15),  side*5.5,  18.3, **kw))
        ax.plot(xp - side*11, 0, "o", color=line_color, ms=2)
        t1, t2 = (127, 233) if side == 1 else (307, 413)
        ax.add_patch(Arc((xp - side*11, 0), 18.3, 18.3,
                         theta1=t1, theta2=t2, color=line_color, lw=lw))
        ax.plot([xp, xp], [-3.66, 3.66], color=line_color, lw=3)
 
    ax.annotate("", xy=(length/2 - 2, -width/2 + 2),
                xytext=(length/2 - 10, -width/2 + 2),
                arrowprops=dict(arrowstyle="->", color=line_color, lw=1, alpha=0.5))
    ax.text(length/2 - 6, -width/2 + 4, attack_label,
            color=line_color, fontsize=7, alpha=0.5, ha="center")
 
def add_third_lines(ax):
    for x in [-17.5, 17.5]:
        ax.axvline(x, color="white", lw=0.8, alpha=0.35, ls="--", zorder=1)
 
def add_third_counts(ax, xs, width=68):
    d = sum(1 for x in xs if x < -17.5)
    m = sum(1 for x in xs if -17.5 <= x <= 17.5)
    a = sum(1 for x in xs if x > 17.5)
    total = max(d + m + a, 1)
    for x_pos, count, label in [(-35, d, "Def"), (0, m, "Mid"), (35, a, "Att")]:
        ax.text(x_pos, -width/2 - 1.5,
                f"{label}\n{count} ({100*count//total}%)",
                ha="center", va="top", color="white", fontsize=8,
                bbox=dict(facecolor="#222", edgecolor="none", alpha=0.7, pad=2))
 
