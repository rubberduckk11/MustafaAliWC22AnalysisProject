        ax_map.set_title(f"{team_label} — Set Piece Locations",
                         color="white", fontsize=10, weight="bold", pad=6)
 
        # ── Panel 2: Outcome breakdown bar chart ──────────────────────────────
        ax_bar = fig.add_subplot(gs[row_i, 1])
        ax_bar.set_facecolor("#1a1a1a")
 
        # Group by setpiece type and outcome
        from collections import Counter
        type_outcomes = {}
        for sp_type in ['C', 'F', 'T', 'G']:
            sub = team_df[team_df["setpieceType"] == sp_type]
            if sub.empty:
                continue
            outcomes = Counter()
            for _, row in sub.iterrows():
                o = row.get("passOutcome") or row.get("crossOutcome") or "?"
                outcomes[OUTCOME_LABEL.get(o, o)] += 1
            type_outcomes[SETPIECE_LABEL.get(sp_type, sp_type)] = outcomes
 
        if type_outcomes:
            all_outcomes = ['Complete', 'Blocked', 'Intercepted',
                            'Out of Play', 'Stoppage', 'Shot at Goal']
            out_colours  = ['#44ff44', '#ffaa00', '#ff4444',
                            '#aaaaaa', '#4488ff', '#ff00ff']
            ys = list(type_outcomes.keys())
