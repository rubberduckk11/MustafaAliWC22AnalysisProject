        ("Seqs with opp (C/H/D)", f"{sum(1 for s in fra_seqs if s['has_opp'])} ({pct(sum(1 for s in fra_seqs if s['has_opp']),len(fra_seqs))})",
                                   f"{sum(1 for s in den_seqs if s['has_opp'])} ({pct(sum(1 for s in den_seqs if s['has_opp']),len(den_seqs))})"),
        ("Seqs ending in goal", str(sum(1 for s in fra_seqs if s['shot_outcome']=='G')),
