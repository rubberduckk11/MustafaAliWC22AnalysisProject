                    continue
                bars = ax_bar.barh(ys, vals, left=bottoms,
                                   color=oc_col, alpha=0.85,
                                   edgecolor="#333", linewidth=0.5,
                                   label=oc)
                for yi, (v, b) in enumerate(zip(vals, bottoms)):
                    if v > 0:
                        ax_bar.text(b + v/2, yi, str(v),
                                    ha='center', va='center',
                                    fontsize=8, color='white', weight='bold')
                bottoms = [b + v for b, v in zip(bottoms, vals)]
 
            ax_bar.legend(facecolor="#333", labelcolor="white",
                          fontsize=7, loc="lower right", framealpha=0.85)
