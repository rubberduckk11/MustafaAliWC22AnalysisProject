# 12. SEQUENCE / BUILD-UP ANALYSIS
# ════════════════════════════════════════════════════════════
def plot_sequence_analysis(df):
    print("Sequence analysis...")
 
    from collections import defaultdict
 
    raw_seqs = defaultdict(lambda: {
        'team': None, 'n_events': 0, 'period': None,
        'start_clock': None, 'end_clock': None,
        'has_shot': False, 'has_opp': False,
        'opp_type': None, 'shot_outcome': None,
        'setpiece': False,
    })
 
    for _, row in df.iterrows():
        seq = row.get("sequence")
        if seq is None or (isinstance(seq, float) and pd.isna(seq)):
            continue
        try:
            seq = int(seq)
        except (ValueError, TypeError):
            continue
        s = raw_seqs[seq]
        s['team'] = row.get("teamName")
        s['period'] = row.get("period")
        clock = row.get("startGameClock") or 0
        if s['start_clock'] is None:
            s['start_clock'] = clock
        s['end_clock'] = clock
        s['n_events'] += 1
        if row.get("possEventType") == "SH":
            s['has_shot'] = True
            s['shot_outcome'] = row.get("shotOutcome")
        if row.get("opportunityType") in ['C','H','D']:
            s['has_opp'] = True
            s['opp_type'] = row.get("opportunityType")
        if row.get("setpieceType") not in [None, 'O', float('nan')]:
            s['setpiece'] = True
 
    seqs = list(raw_seqs.values())
    fra_seqs = [s for s in seqs if s['team'] == 'France' and s['start_clock'] is not None]
    den_seqs = [s for s in seqs if s['team'] != 'France' and s['team'] is not None and s['start_clock'] is not None]
    if not fra_seqs or not den_seqs:
        print("  No sequence data found — check that 'sequence' column is in df.")
        return
    # 15-min windows
    windows = [(0,15,'0-15'), (15,30,'15-30'), (30,45,'30-45'),
               (45,60,'45-60'), (60,75,'60-75'), (75,200,'75-90+')]
    win_labels = [w[2] for w in windows]
 
    def window_stats(seqs_list, windows):
        stats = []
        for wstart, wend, _ in windows:
            w = [s for s in seqs_list
                 if wstart*60 <= (s['start_clock'] or 0) < wend*60]
            stats.append({
                'n': len(w),
                'shots': sum(1 for s in w if s['has_shot']),
                'opps':  sum(1 for s in w if s['has_opp']),
                'avg_len': sum(s['n_events'] for s in w) / max(len(w), 1),
            })
        return stats
 
    fra_stats = window_stats(fra_seqs, windows)
    den_stats = window_stats(den_seqs, windows)
 
    fig = plt.figure(figsize=(22, 14), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(2, 3, hspace=0.35, wspace=0.3,
                           left=0.07, right=0.97, top=0.91, bottom=0.06)
 
    # ── Row 0: Time-series charts ─────────────────────────────────────────────
    # 0,0: Sequences per window
    ax1 = fig.add_subplot(gs[0, 0])
    ax1.set_facecolor("#1a1a1a")
    x = range(len(win_labels))
    ax1.plot(x, [s['n'] for s in fra_stats], 'o-', color="#4488ff",
             lw=2, ms=7, label="France", zorder=4)
    ax1.plot(x, [s['n'] for s in den_stats], 's-', color="#ff4444",
             lw=2, ms=7, label="Opponent", zorder=4)
    ax1.set_xticks(x)
    ax1.set_xticklabels(win_labels, color="white", fontsize=8)
    ax1.set_ylabel("Sequences", color="white", fontsize=9)
    ax1.set_title("Sequences per 15-min Window", color="white",
                  fontsize=10, weight="bold")
    ax1.tick_params(colors="white")
    ax1.legend(facecolor="#333", labelcolor="white", fontsize=8)
    for spine in ax1.spines.values():
        spine.set_edgecolor("#555")
    ax1.set_facecolor("#1a1a1a")
 
    # 0,1: Shots per window
    ax2 = fig.add_subplot(gs[0, 1])
    ax2.set_facecolor("#1a1a1a")
    ax2.bar([xi - 0.2 for xi in x], [s['shots'] for s in fra_stats],
            width=0.38, color="#4488ff", alpha=0.85, label="France")
    ax2.bar([xi + 0.2 for xi in x], [s['shots'] for s in den_stats],
            width=0.38, color="#ff4444", alpha=0.85, label="Opponent")
    ax2.set_xticks(list(x))
    ax2.set_xticklabels(win_labels, color="white", fontsize=8)
    ax2.set_ylabel("Sequences with Shot", color="white", fontsize=9)
    ax2.set_title("Shot-Ending Sequences per Window", color="white",
                  fontsize=10, weight="bold")
    ax2.tick_params(colors="white")
    ax2.legend(facecolor="#333", labelcolor="white", fontsize=8)
    for spine in ax2.spines.values():
        spine.set_edgecolor("#555")
 
    # 0,2: Avg sequence length per window
    ax3 = fig.add_subplot(gs[0, 2])
    ax3.set_facecolor("#1a1a1a")
    ax3.plot(x, [s['avg_len'] for s in fra_stats], 'o-', color="#4488ff",
             lw=2, ms=7, label="France")
    ax3.plot(x, [s['avg_len'] for s in den_stats], 's-', color="#ff4444",
             lw=2, ms=7, label="Opponent")
    ax3.set_xticks(x)
    ax3.set_xticklabels(win_labels, color="white", fontsize=8)
    ax3.set_ylabel("Avg Events per Sequence", color="white", fontsize=9)
    ax3.set_title("Avg Sequence Length per Window", color="white",
                  fontsize=10, weight="bold")
    ax3.tick_params(colors="white")
    ax3.legend(facecolor="#333", labelcolor="white", fontsize=8)
    for spine in ax3.spines.values():
        spine.set_edgecolor("#555")
 
    # ── Row 1: Distribution charts ────────────────────────────────────────────
    # 1,0: Sequence length distribution
    ax4 = fig.add_subplot(gs[1, 0])
    ax4.set_facecolor("#1a1a1a")
    fra_lens = [s['n_events'] for s in fra_seqs]
    den_lens = [s['n_events'] for s in den_seqs]
    bins = range(1, max(max(fra_lens), max(den_lens)) + 2, 2)
    ax4.hist(fra_lens, bins=bins, color="#4488ff", alpha=0.65,
             label=f"France (avg {sum(fra_lens)/len(fra_lens):.1f})", density=True)
    ax4.hist(den_lens, bins=bins, color="#ff4444", alpha=0.65,
             label=f"Opponent (avg {sum(den_lens)/len(den_lens):.1f})", density=True)
    ax4.set_xlabel("Events per Sequence", color="white", fontsize=9)
    ax4.set_ylabel("Density", color="white", fontsize=9)
    ax4.set_title("Sequence Length Distribution", color="white",
                  fontsize=10, weight="bold")
    ax4.tick_params(colors="white")
    ax4.legend(facecolor="#333", labelcolor="white", fontsize=8)
    for spine in ax4.spines.values():
        spine.set_edgecolor("#555")
 
    # 1,1: Sequence outcome breakdown (shot/opportunity/neither)
    ax5 = fig.add_subplot(gs[1, 1])
    ax5.set_facecolor("#1a1a1a")
 
    def outcome_counts(seqs_list):
