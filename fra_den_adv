                            zorder=1)
 
        ax_tbl.set_xlim(0, 1)
        ax_tbl.set_ylim(0, 1)
        ax_tbl.set_title(f"{team_label} — Set Piece Detail",
                         color="white", fontsize=10, weight="bold", pad=6)
 
    fig.suptitle("Set Piece Analysis — FRA vs DEN  |  WC 2022 MD2\n"
                 "★ = Opportunity generated from set piece",
                 color="white", fontsize=13, weight="bold", y=0.98)
 
    out = f"{OUT_DIR}/set_piece_analysis.png"
