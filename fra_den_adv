        opp    = sum(1 for s in seqs_list if s['has_opp'] and not s['has_shot'])
        other  = len(seqs_list) - goal - shot - opp
        return [goal, shot, opp, other]
 
    fra_oc = outcome_counts(fra_seqs)
    den_oc = outcome_counts(den_seqs)
    oc_labels = ['Goal', 'Shot (no goal)', 'Opportunity\n(no shot)', 'No threat']
