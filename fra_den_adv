def _shot_map_single(df, team_df, team_label, out_path):
    """Internal helper — draws shot map for one team."""
 
    SHOT_TYPE = {
        "S": "Side Foot", "V": "Volley",     "F": "Side Foot",
        "B": "Bicycle",   "D": "Div. Header","I": "Sliding",
        "L": "Lob",       "O": "Outstep",
    }
    SHOT_NATURE  = {"P": "Power", "A": "Accurate", "F": "Flick", "T": "Toe Punt"}
    BODY_TYPE    = {
        "R":  "Right Foot",  "L":  "Left Foot", "HE": "Header",
        "RT": "Right Thigh", "LT": "Left Thigh",
        "LC": "Left Shld",   "RC": "Right Shld",
    }
    PRESSURE_LBL = {
        "P": "Pressured", "A": "Press Att.", "L": "Lane Press", "N": "Free",
    }
    HEIGHT_LBL = {
        "BOTTOMTHIRD": "Low",  "MIDDLETHIRD": "Mid",  "TOPTHIRD": "High",
        "G": "Ground", "N": "Over (narrow)", "O": "Over bar", "C": "Crossbar",
    }
 
    def outcome_group(o):
        if o == "G":        return "goal"
        if o in ("S","F"):  return "on_target"
        if o == "B":        return "blocked"
        return "off_target"
 
    OUTCOME_STYLE = {
        "goal":       ("#00ee44", "*",  700, "Goal",             2.0),
        "on_target":  ("#44aaff", "o",  280, "On Target (Saved)", 1.3),
        "blocked":    ("#ffaa00", "D",  220, "Blocked",           1.0),
        "off_target": ("#ff4444", "X",  220, "Off Target",        0.8),
    }
 
    def draw_attacking_half(ax, lc="white", bg="#1e2a1e", lw=1.8):
        ax.set_facecolor(bg)
        ax.set_xlim(17, 56)
        ax.set_ylim(-26, 26)
        ax.set_aspect("equal")
        ax.axis("off")
 
        kw = dict(edgecolor=lc, fill=False, linewidth=lw)
        ax.plot([17, 17],   [-34,  34],  color=lc, lw=lw, ls="--", alpha=0.3)
        ax.plot([17, 52.5], [ 34,  34],  color=lc, lw=lw)
        ax.plot([17, 52.5], [-34, -34],  color=lc, lw=lw)
        ax.plot([52.5, 52.5], [-34, -3.66], color=lc, lw=lw)
        ax.plot([52.5, 52.5], [ 3.66, 34],  color=lc, lw=lw)
        # Goal
        ax.plot([52.5, 52.5], [-3.66, 3.66], color=lc, lw=5)
        ax.plot([52.5, 54.5], [-3.66, -3.66], color=lc, lw=lw)
        ax.plot([52.5, 54.5], [ 3.66,  3.66], color=lc, lw=lw)
        ax.plot([54.5, 54.5], [-3.66,  3.66], color=lc, lw=lw)
        # Penalty area
        ax.add_patch(Rectangle((36.0, -20.15), 16.5, 40.3, **kw))
        # Six-yard box
        ax.add_patch(Rectangle((47.0, -9.15),   5.5, 18.3, **kw))
        # Penalty spot
        ax.plot(41.5, 0, "o", color=lc, ms=3)
        # Penalty arc
        ax.add_patch(Arc((41.5, 0), 18.3, 18.3,
                         theta1=307, theta2=413, color=lc, lw=lw))
        # Attack arrow
        ax.annotate("", xy=(52, -22), xytext=(44, -22),
                    arrowprops=dict(arrowstyle="->", color=lc, lw=1, alpha=0.4))
        ax.text(48, -23.5, "attack →", color=lc, fontsize=7, alpha=0.4, ha="center")
 
    RESULT_COLOURS = {
        "goal":       "#00ee44",
        "on_target":  "#44aaff",
        "blocked":    "#ffaa00",
        "off_target": "#ff4444",
    }
    RESULT_LABELS = {
        "goal": "GOAL", "on_target": "On Target",
        "blocked": "Blocked", "off_target": "Off Target",
    }
 
    # ── Figure: pitch left, table right ──────────────────────────────────────
    fig = plt.figure(figsize=(26, 10), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(1, 2, width_ratios=[1, 1.3],
                           hspace=0.1, wspace=0.06,
