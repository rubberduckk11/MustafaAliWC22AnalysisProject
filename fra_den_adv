LINE_COLORS = {
    "D":   ("#ff4444", "Defense only"),
    "M":   ("#ffaa00", "Midfield only"),
    "MD":  ("#ff6600", "Mid + Defense"),
    "A":   ("#44ff44", "Attack only"),
    "AM":  ("#00ffaa", "Attack + Mid"),
    "AD":  ("#ff00ff", "Attack + Defense (bypasses mid)"),
    "AMD": ("#ffffff", "All three lines"),
