                    fontsize=9, color="white", weight="bold",
                    va="top", ha="left", fontfamily="monospace")
 
    # Divider line
    ax_tbl.plot([0, 1], [header_y - 0.02, header_y - 0.02],
                color="#555555", lw=1,
                transform=ax_tbl.transAxes)
 
    # Rows
    for ri, (_, s) in enumerate(sorted_df.iterrows()):
        y = header_y - 0.04 - ri * row_h
 
        grp        = outcome_group(s["shotOutcome"])
        result_col = RESULT_COLOURS[grp]
        result_lbl = RESULT_LABELS[grp]
 
        body    = BODY_TYPE.get(s.get("bodyType",""), s.get("bodyType",""))
        stype   = SHOT_TYPE.get(s.get("shotType",""), s.get("shotType",""))
        snature = SHOT_NATURE.get(s.get("shotNature",""), s.get("shotNature",""))
        height  = HEIGHT_LBL.get(s.get("shotInitialHeight",""), "—")
        press   = PRESSURE_LBL.get(s.get("pressureType",""), "—")
        player  = s.get("shooter") or ""
        clock   = s.get("formattedClock","")
 
        row_vals = [
            str(ri + 1), clock, player, body,
            stype, snature, height, press, result_lbl,
