# 14. MBAPPE SPACE VS ACTION MAP
# ════════════════════════════════════════════════════════════
def plot_mbappe_space_vs_action(df):
    print("Mbappe space vs action map...")
 
    import numpy as np
    MBAPPE_J = "10"
    france_events = df[df["homeTeam"] == True].copy()
 
    records = []
    for _, row in france_events.iterrows():
        hp = row.get("_home_players") or {}
        ap = row.get("_away_players") or {}
        mbappe = hp.get(MBAPPE_J)
        if not mbappe:
            continue
 
        mx = mbappe.get("x", 0)
        my = mbappe.get("y", 0)
        if str(row.get("period")) == "2":
            mx, my = -mx, -my
 
        min_dist = 999
        for p in ap.values():
            ax_ = p.get("x", 0)
            ay_ = p.get("y", 0)
            if str(row.get("period")) == "2":
                ax_, ay_ = -ax_, -ay_
            d = np.sqrt((mx - ax_)**2 + (my - ay_)**2)
            if d < min_dist:
                min_dist = d
 
        had_ball  = row.get("playerName") == "Kylian Mbappé"
        action    = row.get("possEventType") if had_ball else None
 
        records.append({
            'mx': mx, 'my': my,
            'dist': min_dist,
            'had_ball': had_ball,
            'action': action,
            'clock': (row.get("startGameClock") or 0) / 60,
            'shot': action == "SH",
            'shot_outcome': row.get("shotOutcome") if action == "SH" else None,
        })
 
    fig = plt.figure(figsize=(22, 10), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(1, 3, width_ratios=[1.3, 1.3, 1],
                           wspace=0.12, left=0.03, right=0.97,
                           top=0.90, bottom=0.05)
 
    # ── Panel 1: Space map (all events, colour = dist) ────────────────────────
    ax1 = fig.add_subplot(gs[0, 0])
    draw_pitch(ax1)
 
    no_ball = [r for r in records if not r['had_ball']]
    xs  = [r['mx'] for r in no_ball]
    ys  = [r['my'] for r in no_ball]
    ds  = [r['dist'] for r in no_ball]
 
    sc = ax1.scatter(xs, ys, c=ds, cmap="RdYlGn", vmin=0, vmax=20,
                     s=12, alpha=0.55, zorder=4)
    cb = fig.colorbar(sc, ax=ax1, fraction=0.025, pad=0.02)
    cb.set_label("Distance to closest defender (m)", color="white", fontsize=8)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
 
    # Overlay where he had the ball
    with_ball = [r for r in records if r['had_ball']]
    ax1.scatter([r['mx'] for r in with_ball],
                [r['my'] for r in with_ball],
                c="#ffffff", s=50, marker="D", alpha=0.7, zorder=6,
                edgecolors="#333", linewidths=0.5,
                label=f"Had ball (n={len(with_ball)})")
    ax1.legend(facecolor="#333", labelcolor="white", fontsize=8, loc="upper left")
 
    tight_off  = sum(1 for r in no_ball if r['dist'] <= 5)
    tight_on   = sum(1 for r in with_ball if r['dist'] <= 5)
    ax1.set_title(
        f"Mbappé Position — Space vs Tight Marking\n"
        f"Off ball: {tight_off}/{len(no_ball)} events within 5m ({100*tight_off//max(len(no_ball),1)}%)   "
        f"On ball: {tight_on}/{len(with_ball)} ({100*tight_on//max(len(with_ball),1)}%)",
        color="white", fontsize=9, weight="bold", pad=6)
 
    # ── Panel 2: Action locations coloured by space ───────────────────────────
    ax2 = fig.add_subplot(gs[0, 1])
    draw_pitch(ax2)
 
    ACTION_MARKER = {
        "PA": ("o",  120, "Pass"),
        "SH": ("*",  400, "Shot"),
        "BC": ("s",  120, "Ball Carry"),
        "CH": ("D",  120, "Challenge/Dribble"),
        "TC": ("^",  100, "Touch"),
        "CR": ("p",  150, "Cross"),
        "IT": ("o",   80, "Initial Touch"),
    }
    ACTION_COLOURS_DARK = {
        "PA": "#4488ff", "SH": "#00ee44", "BC": "#ffaa00",
        "CH": "#ff4444", "TC": "#aaaaaa", "CR": "#ff88ff", "IT": "#88ffff",
    }
 
    plotted_actions = set()
    for r in with_ball:
        act = r.get('action') or 'IT'
        marker, size, lbl = ACTION_MARKER.get(act, ("o", 100, act))
        col = ACTION_COLOURS_DARK.get(act, "#ffffff")
        # Colour by space: green if free, red if tight
        space_col = "#00ee44" if r['dist'] > 5 else "#ff4444"
        ax2.scatter(r['mx'], r['my'], c=space_col, s=size,
                    marker=marker, alpha=0.9, zorder=6,
                    edgecolors=col, linewidths=1.5)
        if act not in plotted_actions:
            plotted_actions.add(act)
 
    # Legend for action types
    from matplotlib.lines import Line2D
    leg_els = [
        Line2D([0],[0], lw=0, marker=ACTION_MARKER.get(a,("o",0,""))[0],
               markersize=8, markerfacecolor="#888888",
               markeredgecolor=ACTION_COLOURS_DARK.get(a,"white"),
               markeredgewidth=1.5,
               label=ACTION_MARKER.get(a,("o",0,a))[2])
        for a in plotted_actions
    ]
    leg_els += [
        Line2D([0],[0], lw=0, marker="o", markersize=8,
               markerfacecolor="#00ee44", label="Free (>5m)"),
        Line2D([0],[0], lw=0, marker="o", markersize=8,
               markerfacecolor="#ff4444", label="Tight (≤5m)"),
    ]
    ax2.legend(handles=leg_els, facecolor="#333", labelcolor="white",
               fontsize=7.5, loc="upper left", framealpha=0.85)
    ax2.set_title("Mbappé Actions — Free vs Tight Marked\n"
                  "Fill = space (green=free, red=tight)   Edge = action type",
                  color="white", fontsize=9, weight="bold", pad=6)
 
    # ── Panel 3: Space over time + action markers ─────────────────────────────
    ax3 = fig.add_subplot(gs[0, 2])
    ax3.set_facecolor("#1a1a1a")
 
    all_clocks = [r['clock'] for r in records]
    all_dists  = [r['dist']  for r in records]
 
    # Rolling average
    w = 15
    if len(all_dists) > w:
        smooth_d = np.convolve(all_dists, np.ones(w)/w, mode='valid')
        smooth_c = all_clocks[w//2:w//2+len(smooth_d)]
        ax3.fill_between(smooth_c, smooth_d, alpha=0.2, color="#44aaff")
        ax3.plot(smooth_c, smooth_d, color="#44aaff", lw=2, label="Avg dist (rolling)")
 
    # Mark shot events
    shot_recs = [r for r in records if r['shot']]
    for sr in shot_recs:
        col = "#00ee44" if sr['shot_outcome'] == 'G' else \
              "#44aaff" if sr['shot_outcome'] in ('S','F') else \
              "#ffaa00" if sr['shot_outcome'] == 'B' else "#ff4444"
        ax3.axvline(sr['clock'], color=col, lw=1.5, alpha=0.8, zorder=5)
        ax3.scatter(sr['clock'], sr['dist'], c=col, s=120, marker="*",
                    zorder=6, edgecolors="white", linewidths=0.8)
 
    ax3.axhline(5, color="#ffff00", lw=1, ls="--", alpha=0.6,
                label="5m threshold")
    ax3.axvline(45, color="#888", lw=1, ls="--", alpha=0.5)
    ax3.text(45.5, ax3.get_ylim()[1] if ax3.get_ylim()[1] > 0 else 20,
             "HT", color="#888", fontsize=7.5, va="top")
 
    ax3.set_xlabel("Match Minute", color="white", fontsize=9)
    ax3.set_ylabel("Distance to closest defender (m)", color="white", fontsize=9)
    ax3.set_title("Mbappé Space Over Time\n★ = Shot event",
                  color="white", fontsize=9, weight="bold", pad=6)
    ax3.tick_params(colors="white")
    ax3.legend(facecolor="#333", labelcolor="white", fontsize=7.5)
    for spine in ax3.spines.values():
        spine.set_edgecolor("#555")
 
    fig.suptitle("Mbappé — Space vs Action Analysis  |  FRA vs DEN  |  WC 2022 MD2",
                 color="white", fontsize=13, weight="bold", y=0.97)
 
    out = f"{OUT_DIR}/mbappe_space_vs_action.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
