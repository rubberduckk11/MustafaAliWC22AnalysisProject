# 3.  PASSING NETWORK
# ════════════════════════════════════════════════════════════
def plot_passing_network(df):
    print("[1/6] Passing network...")
    france_passes = df[
        (df["homeTeam"] == True) &
        (df["possEventType"] == "PA") &
        df["passer"].notna() &
        df["ball_x"].notna()
    ].copy()
 
    node_pos = (france_passes.groupby("passer")[["ball_x", "ball_y"]]
                .mean()
                .rename(columns={"ball_x": "x", "ball_y": "y"}))
 
    completed    = france_passes[france_passes["passOutcome"] == "C"]
    edge_counts  = defaultdict(int)
    all_attempts = defaultdict(int)
    for _, row in completed.iterrows():
        if pd.notna(row["receiver"]):
            edge_counts[(row["passer"], row["receiver"])] += 1
    for _, row in france_passes.iterrows():
        if pd.notna(row["target"]):
            all_attempts[(row["passer"], row["target"])] += 1
 
    fig = plt.figure(figsize=(20, 9), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(1, 2, width_ratios=[3, 1], wspace=0.05)
    ax  = fig.add_subplot(gs[0, 0])
    ax_table = fig.add_subplot(gs[0, 1])
    draw_pitch(ax)
 
    max_edge = max(edge_counts.values(), default=1)
    for (passer, receiver), count in edge_counts.items():
        if count < 2:
            continue
        if passer not in node_pos.index or receiver not in node_pos.index:
            continue
        x1, y1 = node_pos.loc[passer, ["x", "y"]]
        x2, y2 = node_pos.loc[receiver, ["x", "y"]]
        comp = count / max(all_attempts.get((passer, receiver), 1), 1)
        lw   = 0.8 + 5.5 * (count / max_edge)
        col  = plt.cm.RdYlGn(comp)
        ax.annotate("", xy=(x2, y2), xytext=(x1, y1),
                    arrowprops=dict(arrowstyle="-|>", color=col,
                                   lw=lw, mutation_scale=14, alpha=0.85))
 
    pass_counts = france_passes.groupby("passer").size()
    for player, (px, py) in node_pos.iterrows():
        n    = pass_counts.get(player, 1)
        size = 150 + 700 * (n / pass_counts.max())
        ax.scatter(px, py, s=size, c="#1f77b4", zorder=5,
                   edgecolors="white", linewidths=2)
        label = SHORT_NAME.get(player, player.split()[-1])
        ax.text(px, py + 3, label, ha="center", va="bottom",
                fontsize=8, color="white", weight="bold", zorder=6)
 
    sm = ScalarMappable(cmap="RdYlGn", norm=Normalize(0, 1))
    sm.set_array([])
    cb = fig.colorbar(sm, ax=ax, fraction=0.022, pad=0.02)
    cb.set_label("Pass completion rate", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
 
    ax.set_title("France Passing Network — FRA vs DEN (WC MD2 2022)",
                 color="white", fontsize=13, weight="bold", pad=10)
    ax.text(0, -37,
            "Nodes = avg passing position  |  Size = pass volume  |  "
            "Arrow width = frequency  |  Colour = completion%",
            ha="center", color="#aaaaaa", fontsize=7.5)
 
    ax_table.set_facecolor("#1a1a1a")
    ax_table.axis("off")
 
    pair_keys = set(edge_counts.keys()) | set(all_attempts.keys())
    rows_table = []
    for (p, r) in pair_keys:
        comp = edge_counts.get((p, r), 0)
        att  = all_attempts.get((p, r), comp)
        if att < 2:
            continue
        rows_table.append((p, r, comp, att))
    rows_table.sort(key=lambda t: (-t[2], -t[3]))
    rows_table = rows_table[:20]
 
    ax_table.text(0.5, 0.985, f"Top {len(rows_table)} pass combinations",
                  transform=ax_table.transAxes, ha="center", va="top",
                  color="white", fontsize=12, weight="bold")
    ax_table.text(0.02, 0.945, "From → To", transform=ax_table.transAxes,
                  ha="left", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_table.text(0.78, 0.945, "Comp / Att", transform=ax_table.transAxes,
                  ha="right", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_table.text(0.99, 0.945, "%", transform=ax_table.transAxes,
                  ha="right", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_table.plot([0.02, 0.99], [0.93, 0.93],
                  transform=ax_table.transAxes, color="#555", lw=0.8)
 
    if rows_table:
        y_top, y_bottom = 0.91, 0.02
        step = (y_top - y_bottom) / max(len(rows_table), 1)
        for idx, (p, r, comp, att) in enumerate(rows_table):
            y = y_top - idx * step
            pct = 100 * comp / max(att, 1)
            row_color = plt.cm.RdYlGn(comp / max(att, 1))
            p_short = SHORT_NAME.get(p, p.split()[-1])
            r_short = SHORT_NAME.get(r, r.split()[-1])
            ax_table.text(0.02, y, f"{p_short} → {r_short}",
                          transform=ax_table.transAxes,
                          ha="left", va="top", color="white", fontsize=8.5)
            ax_table.text(0.78, y, f"{comp} / {att}",
                          transform=ax_table.transAxes,
                          ha="right", va="top", color="white", fontsize=8.5)
            ax_table.text(0.99, y, f"{pct:.0f}",
                          transform=ax_table.transAxes,
                          ha="right", va="top", color=row_color,
                          fontsize=8.5, weight="bold")
 
    out = f"{OUT_DIR}/passing_network_france.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
