        draw_opportunity_arrows(sub, col)
        lbl = {"C": "Chance Created", "H": "Half Chance", "D": "Dangerous"}[otype]
        patches.append(mpatches.Patch(color=col, label=f"DEN {lbl} (n={counts[key]})"))
 
    # Denmark-benefiting negatives
    for otype, col, lbl in [
        ("N", "#cc00cc", f"DEN Neg Chance via FRA error (n={den_neg_n})"),
        ("P", "#9933ff", f"DEN Neg Dangerous via FRA error (n={den_neg_p})"),
    ]:
        sub = den_neg[den_neg["opportunityType"] == otype]
        if sub.empty:
            continue
        draw_opportunity_arrows(sub, col, alpha_arrow=0.35, alpha_dot=0.55)
        patches.append(mpatches.Patch(color=col, label=lbl))
 
    # Goals
    for _, g in goals.iterrows():
        is_france = g["homeTeam"]
        gx, gy = g["ball_x"], g["ball_y"]
        ax.scatter(gx, gy,
                   c="#00ff00" if is_france else "#ff4444",
                   s=500, marker="*", zorder=8,
                   edgecolors="white", linewidths=1.5)
        name = SHORT_NAME.get(g["shooter"], (g["shooter"] or "").split()[-1])
        ax.text(gx, gy + 3.5, f"GOAL: {name}",
                ha="center", fontsize=8, color="white",
                weight="bold", zorder=9)
 
    patches += [
        mpatches.Patch(color="#00ff00", label="France Goal"),
        mpatches.Patch(color="#ff4444", label="Denmark Goal"),
    ]
 
    style_legend = [
        Line2D([0], [0], color="white", lw=1.5, linestyle="-",  label="Pass"),
        Line2D([0], [0], color="white", lw=1.5, linestyle="--", label="Cross"),
        Line2D([0], [0], color="white", lw=1.5, linestyle=":",  label="Dribble"),
        Line2D([0], [0], color="white", lw=1.5, linestyle="-.", label="Clearance"),
        Line2D([0], [0], color="white", lw=0, marker="*",
               markersize=10, label="★ = Chance Created"),
        Line2D([0], [0], color="white", lw=0, marker="o",
               markersize=6,  label="● = Half Chance / Dangerous"),
        Line2D([0], [0], color="white", lw=0, marker="o",
               markersize=3,  label="· = Origin of event"),
    ]
 
    leg1 = ax.legend(handles=patches, facecolor="#333", labelcolor="white",
                     fontsize=8, loc="upper left", framealpha=0.85, ncol=2,
                     title="Team & Opportunity Level", title_fontsize=8)
    leg1.get_title().set_color("white")
    ax.add_artist(leg1)
 
    leg2 = ax.legend(handles=style_legend, facecolor="#333", labelcolor="white",
                     fontsize=8, loc="lower left", framealpha=0.85,
                     title="Event Type & Marker", title_fontsize=8)
    leg2.get_title().set_color("white")
 
    ax.set_title(
        "Chance Creation & Goal Map — FRA vs DEN (WC MD2 2022)\n"
        "France attacks →   |   Warm colours = France benefit   |   "
        "Cool colours = Denmark benefit   |   Arrow: passer → receiver",
