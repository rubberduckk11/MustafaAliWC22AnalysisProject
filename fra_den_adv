def plot_set_pieces(df):
    print("Set piece analysis...")
 
    SETPIECE_LABEL = {
        'C': 'Corner', 'F': 'Free Kick', 'T': 'Throw In',
        'G': 'Goal Kick', 'K': 'Kick Off', 'P': 'Penalty', 'D': 'Drop Ball',
    }
    CROSS_TYPE = {'I': 'Inswinger', 'O': 'Outswinger', 'D': 'Drilled',
                  'F': 'Floated', 'P': 'Placed'}
    OUTCOME_LABEL = {
        'C': 'Complete', 'D': 'Intercepted', 'O': 'Out of Play',
        'B': 'Blocked', 'S': 'Stoppage', 'G': 'Goal', 'I': 'Shot at Goal',
    }
    OPP_LABEL = {'C': 'Chance Created', 'H': 'Half Chance',
                 'D': 'Dangerous', 'N': 'Neg Chance', 'P': 'Neg Dangerous'}
 
    sp_df = df[
        df["setpieceType"].notna() &
        (df["setpieceType"] != "O") &
        (df["setpieceType"] != "K")
    ].copy()
 
    fra_sp = sp_df[sp_df["homeTeam"] == True].copy()
    den_sp = sp_df[sp_df["homeTeam"] == False].copy()
 
    # Flip Denmark coords
    den_sp["ball_x"] = -den_sp["ball_x"]
    den_sp["ball_y"] = -den_sp["ball_y"]
 
    fig = plt.figure(figsize=(26, 16), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(2, 3, width_ratios=[1.2, 1, 1],
                           hspace=0.28, wspace=0.12,
                           left=0.03, right=0.97,
                           top=0.92, bottom=0.04)
 
    SP_COLOURS = {
        'C': '#ff6600', 'F': '#44aaff', 'T': '#ffff00',
        'G': '#aaaaaa', 'P': '#ff3333', 'D': '#00ffaa',
    }
    OPP_COLOURS = {
        'C': '#ff3333', 'H': '#ff8800', 'D': '#ffff00',
        'N': '#4488ff', 'P': '#9933ff',
    }
 
    def draw_sp_pitch(ax):
        draw_pitch(ax, attack_label="attack →")
 
    for row_i, (team_df, team_label) in enumerate([
        (fra_sp, "France"), (den_sp, "Opponent")
    ]):
        # ── Panel 1: Location map ─────────────────────────────────────────────
        ax_map = fig.add_subplot(gs[row_i, 0])
        draw_sp_pitch(ax_map)
 
        for sp_type, colour in SP_COLOURS.items():
            sub = team_df[
                team_df["setpieceType"] == sp_type &
                team_df["ball_x"].notna()
            ] if False else team_df[
                (team_df["setpieceType"] == sp_type) &
                team_df["ball_x"].notna()
            ]
            if sub.empty:
                continue
            ax_map.scatter(sub["ball_x"], sub["ball_y"],
                           c=colour, s=120, zorder=5, alpha=0.85,
                           edgecolors="white", linewidths=0.8,
                           label=f"{SETPIECE_LABEL.get(sp_type, sp_type)} (n={len(sub)})")
 
        # Mark opportunities from set pieces
        opp_sub = team_df[team_df["opportunityType"].notna() & team_df["ball_x"].notna()]
        if not opp_sub.empty:
            for _, row in opp_sub.iterrows():
                oc = OPP_COLOURS.get(row["opportunityType"], "#ffffff")
                ax_map.scatter(row["ball_x"], row["ball_y"],
                               c=oc, s=300, marker="*", zorder=7,
                               edgecolors="white", linewidths=1.2)
 
        ax_map.legend(facecolor="#333", labelcolor="white",
