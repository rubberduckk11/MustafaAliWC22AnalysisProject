def plot_lines_broken(df):
    print("[3/6] Lines broken...")
 
    france_lb = df[
        (df["homeTeam"] == True) &
        df["linesBroken"].notna() &
        df["ball_x"].notna()
    ].copy()
 
    den_lb = df[
        (df["homeTeam"] == False) &
        df["linesBroken"].notna() &
        df["ball_x"].notna()
    ].copy()
    den_lb = den_lb.copy()
    den_lb["ball_x"] = -den_lb["ball_x"]
    den_lb["ball_y"] = -den_lb["ball_y"]
    den_lb["end_x"]  = -den_lb["end_x"]
    den_lb["end_y"]  = -den_lb["end_y"]
 
    fig, axes = plt.subplots(1, 2, figsize=(18, 7), facecolor="#1a1a1a")
 
    for ax, data, title, arrow in [
        (axes[0], france_lb, "France Line-Breaking Events",  "France attack →"),
        (axes[1], den_lb,    "Denmark Line-Breaking Events", "Denmark attack →"),
    ]:
        draw_pitch(ax, attack_label=arrow)
        patches = []
        for ltype, (col, label) in LINE_COLORS.items():
            sub = data[data["linesBroken"] == ltype]
            if sub.empty:
                continue
            for _, row in sub.iterrows():
                x1, y1 = row["ball_x"], row["ball_y"]
                x2, y2 = row["end_x"],  row["end_y"]
                if pd.isna(x2) or pd.isna(y2):
                    ax.scatter(x1, y1, c=col, s=70, alpha=0.85, zorder=4,
                               edgecolors="#333", linewidths=0.5)
                    continue
                ax.scatter(x1, y1, c=col, s=35, alpha=0.9, zorder=5,
                           edgecolors="#222", linewidths=0.4)
                ax.annotate("", xy=(x2, y2), xytext=(x1, y1),
                            arrowprops=dict(arrowstyle="-|>", color=col,
                                           lw=1.4, mutation_scale=10, alpha=0.75),
                            zorder=4)
            patches.append(mpatches.Patch(color=col, label=f"{label} (n={len(sub)})"))
 
        ax.legend(handles=patches, facecolor="#333", labelcolor="white",
                  fontsize=8, loc="upper left", framealpha=0.8)
        ax.set_title(title, color="white", fontsize=12, weight="bold", pad=8)
 
    fig.suptitle("Line-Breaking Events — FRA vs DEN (WC MD2 2022)",
                 color="white", fontsize=14, weight="bold", y=1.02)
 
    out = f"{OUT_DIR}/lines_broken.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
