    for i, (oc_col, lbl) in enumerate(zip(oc_colours, oc_labels)):
        ax5.bar(i - 0.2, fra_pct[i], width=0.38, color=oc_col,
                alpha=0.85, edgecolor="#333")
        ax5.bar(i + 0.2, den_pct[i], width=0.38, color=oc_col,
                alpha=0.5, edgecolor="#333", hatch="//")
        ax5.text(i - 0.2, fra_pct[i] + 0.5, f"{fra_pct[i]:.0f}%",
