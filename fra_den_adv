def plot_press_map(df):
    print("[2/6] Press map...")
 
    den_press = df[
        (df["homeTeam"] == True) &
        (df["pressureType"].isin(["P", "A"])) &
        df["ball_x"].notna()
    ].copy()
    den_full = den_press[den_press["pressureType"] == "P"]
 
    fra_press = df[
        (df["homeTeam"] == False) &
        (df["pressureType"].isin(["P", "A"])) &
        df["ball_x"].notna()
    ].copy()
    fra_full = fra_press[fra_press["pressureType"] == "P"]
 
    fig, axes = plt.subplots(1, 2, figsize=(20, 8), facecolor="#1a1a1a")
 
    datasets = [
        (axes[0], den_press, den_full,
         "DEN Pressure on France\n(France in possession | France attacks →)",
         "Where France were pressured by Denmark"),
        (axes[1], fra_press, fra_full,
         "France Pressure on DEN\n(DEN in possession | France attacks →)",
         "Where France pressed Denmark  (DEN half = negative x)"),
    ]
 
    for ax, data, full_data, title, subtitle in datasets:
        draw_pitch(ax)
        add_third_lines(ax)
        xs = data["ball_x"].values
        ys = data["ball_y"].values
        ax.hexbin(xs, ys, gridsize=18, cmap="hot", alpha=0.70,
                  extent=[-52.5, 52.5, -34, 34], mincnt=1, zorder=2)
        ax.scatter(full_data["ball_x"], full_data["ball_y"],
                   c="cyan", s=20, alpha=0.55, zorder=4,
                   label=f"Player Pressured (n={len(full_data)})")
        add_third_counts(ax, xs)
        ax.legend(facecolor="#333", labelcolor="white", fontsize=8, loc="upper left")
        ax.set_title(title, color="white", fontsize=11, weight="bold", pad=6)
        ax.text(0, 38, subtitle, ha="center", color="#aaaaaa", fontsize=8)
 
    sm = ScalarMappable(cmap="hot")
    sm.set_array([])
    cb = fig.colorbar(sm, ax=axes, fraction=0.015, pad=0.02)
    cb.set_label("Pressure density", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
 
    fig.suptitle(
        "Pressure Maps — FRA vs DEN (WC MD2 2022)\n"
        "Both maps: France attacks →    |    DEN possession = ball at negative x",
        color="white", fontsize=13, weight="bold", y=1.02)
 
    out = f"{OUT_DIR}/press_map.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
