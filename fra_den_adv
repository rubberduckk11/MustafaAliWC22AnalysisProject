# TEAM SHOTS
def plot_shot_map(df):
    print("Shot map...")
 
    shots = df[
        (df["possEventType"] == "SH") &
        df["shooter"].notna()
    ].copy()
 
    fra = shots[shots["homeTeam"] == True].copy()
    den = shots[shots["homeTeam"] == False].copy()
    den["ball_x"] = -den["ball_x"]
    den["ball_y"] = -den["ball_y"]
 
    SHOT_TYPE = {
        "S": "Side Foot", "V": "Volley",  "F": "Side Foot",
        "B": "Bicycle",   "D": "Div.Hdr", "I": "Sliding",
        "L": "Lob",       "O": "Out.Foot",
    }
    SHOT_NATURE = {"P": "Power", "A": "Accurate", "F": "Flick", "T": "Toe Punt"}
    BODY_TYPE   = {
        "R": "RF", "L": "LF", "HE": "Head",
        "RT": "R.Thigh", "LT": "L.Thigh",
        "LC": "L.Shld",  "RC": "R.Shld",
    }
    PRESSURE_LABEL = {"P": "Pressed", "A": "Press Att.", "L": "Lane", "N": "Free"}
    HEIGHT_LABEL   = {
        "BOTTOMTHIRD": "Low", "MIDDLETHIRD": "Mid", "TOPTHIRD": "High",
        "G": "Ground", "N": "Over(narrow)", "O": "Over", "C": "Bar",
    }
 
    def outcome_group(o):
        if o == "G":            return "goal"
        if o in ("S", "F"):     return "on_target"
        if o == "B":            return "blocked"
        return "off_target"
 
    OUTCOME_STYLE = {
        "goal":       ("#00ee44", "*",  500, "Goal",           2.0),
        "on_target":  ("#44aaff", "o",  220, "On Target",      1.2),
        "blocked":    ("#ffaa00", "D",  180, "Blocked",        1.0),
        "off_target": ("#ff4444", "X",  180, "Off Target",     0.8),
    }
 
    # ── Attacking-half pitch draw ─────────────────────────────────────────────
    def draw_attacking_half(ax, length=105, width=68, lc="white", bg="#1e1e1e", lw=1.5):
        ax.set_facecolor(bg)
        # Show from centre to goal + a little beyond
        ax.set_xlim(0, length/2 + 4)
        ax.set_ylim(-width/2 - 3, width/2 + 3)
        ax.set_aspect("equal")
        ax.axis("off")
 
        kw = dict(edgecolor=lc, fill=False, linewidth=lw)
        # Half pitch boundary
        ax.plot([0, 0],           [-width/2, width/2], color=lc, lw=lw)
        ax.plot([0, length/2],    [ width/2,  width/2], color=lc, lw=lw)
        ax.plot([0, length/2],    [-width/2, -width/2], color=lc, lw=lw)
        ax.plot([length/2, length/2], [-width/2, -3.66], color=lc, lw=lw)
        ax.plot([length/2, length/2], [ 3.66,  width/2], color=lc, lw=lw)
 
        # Centre circle (half)
        import numpy as np
        theta = np.linspace(-np.pi/2, np.pi/2, 100)
        ax.plot(9.15*np.cos(theta), 9.15*np.sin(theta), color=lc, lw=lw)
        ax.plot(0, 0, "o", color=lc, ms=2)
 
        # Penalty area
        ax.add_patch(Rectangle((length/2 - 16.5, -20.15), 16.5, 40.3, **kw))
        # Six-yard box
        ax.add_patch(Rectangle((length/2 - 5.5, -9.15), 5.5, 18.3, **kw))
        # Penalty spot
        ax.plot(length/2 - 11, 0, "o", color=lc, ms=2)
        # Penalty arc
        ax.add_patch(Arc((length/2 - 11, 0), 18.3, 18.3,
                         theta1=127, theta2=233, color=lc, lw=lw))
        # Goal
        ax.plot([length/2, length/2], [-3.66, 3.66], color=lc, lw=4)
 
        # Attack direction arrow
        ax.annotate("", xy=(length/2 - 1, -width/2 + 2),
                    xytext=(length/2 - 8, -width/2 + 2),
                    arrowprops=dict(arrowstyle="->", color=lc, lw=1, alpha=0.4))
        ax.text(length/2 - 4.5, -width/2 + 3.8, "attack →",
                color=lc, fontsize=7, alpha=0.4, ha="center")
 
    # ── Figure ────────────────────────────────────────────────────────────────
    fig, axes = plt.subplots(1, 2, figsize=(20, 9), facecolor="#1a1a1a")
 
    for ax, team_df, team_label in [
        (axes[0], fra, "France"),
        (axes[1], den, "Opponent"),
    ]:
        draw_attacking_half(ax)
 
        for _, row in team_df.iterrows():
            bx = row["ball_x"]
            by = row["ball_y"]
            if pd.isna(bx) or pd.isna(by):
                continue
 
            grp = outcome_group(row["shotOutcome"])
            col, marker, size, label, lw = OUTCOME_STYLE[grp]
 
            ax.scatter(bx, by, c=col, s=size, marker=marker,
                       zorder=6, alpha=0.93,
                       edgecolors="white", linewidths=lw)
 
        # ── Clean table of shots below pitch ─────────────────────────────────
        # Build rows: clock | player | body | type | nature | height | pressure | outcome
        table_rows = []
        for _, row in team_df.sort_values("startGameClock").iterrows():
            grp     = outcome_group(row["shotOutcome"])
            col     = OUTCOME_STYLE[grp][0]
            body    = BODY_TYPE.get(row.get("bodyType",""), row.get("bodyType",""))
            stype   = SHOT_TYPE.get(row.get("shotType",""), row.get("shotType",""))
            snature = SHOT_NATURE.get(row.get("shotNature",""), row.get("shotNature",""))
            height  = HEIGHT_LABEL.get(row.get("shotInitialHeight",""), "")
            press   = PRESSURE_LABEL.get(row.get("pressureType",""), "")
            player  = (row.get("shooter") or "").split()[-1]
            clock   = row.get("formattedClock","")
            outcome = {"goal":"GOAL","on_target":"On tgt","blocked":"Blocked","off_target":"Off tgt"}[grp]
            table_rows.append((clock, player, body, stype, snature, height, press, outcome, col))
 
        # Draw table using ax.table positioned below the pitch
        col_labels = ["Time","Player","Body","Type","Nature","Height","Pressure","Result"]
        cell_text  = [[r[0],r[1],r[2],r[3],r[4],r[5],r[6],r[7]] for r in table_rows]
        cell_colors= [["#2a2a2a"]*8 for _ in table_rows]
        # Colour the Result cell by outcome
        for i, r in enumerate(table_rows):
            cell_colors[i][7] = r[8] + "44"  # hex with alpha suffix trick
 
        tbl = ax.table(
            cellText=cell_text,
            colLabels=col_labels,
            cellColours=cell_colors,
            loc="bottom",
            bbox=[0, -0.72, 1, 0.65],
        )
        tbl.auto_set_font_size(False)
        tbl.set_fontsize(7.2)
        for (row_i, col_i), cell in tbl.get_celld().items():
            cell.set_edgecolor("#444444")
            cell.set_text_props(color="white")
            if row_i == 0:
                cell.set_facecolor("#111111")
                cell.set_text_props(color="white", fontweight="bold")
 
        # ── Stats summary ────────────────────────────────────────────────────
        n       = len(team_df)
        goals   = len(team_df[team_df["shotOutcome"] == "G"])
        on_tgt  = len(team_df[team_df["shotOutcome"].isin(["S","F"])])
        blocked = len(team_df[team_df["shotOutcome"] == "B"])
        off_tgt = n - goals - on_tgt - blocked
        pressed = len(team_df[team_df["pressureType"] == "P"])
 
        summary = f"Shots: {n}   Goals: {goals}   On target: {on_tgt}   Blocked: {blocked}   Off target: {off_tgt}   Under pressure: {pressed}/{n}"
        ax.set_title(f"{team_label} — Shots\n{summary}",
                     color="white", fontsize=11, weight="bold", pad=10)
 
    # ── Shared legend ─────────────────────────────────────────────────────────
    from matplotlib.lines import Line2D
    legend_els = [
        Line2D([0],[0], color="white", lw=0, marker="*", markersize=13,
               markerfacecolor="#00ee44", label="Goal"),
        Line2D([0],[0], color="white", lw=0, marker="o", markersize=10,
               markerfacecolor="#44aaff", label="On Target (Saved)"),
        Line2D([0],[0], color="white", lw=0, marker="D", markersize=9,
               markerfacecolor="#ffaa00", label="Blocked"),
        Line2D([0],[0], color="white", lw=0, marker="X", markersize=9,
               markerfacecolor="#ff4444", label="Off Target"),
    ]
    fig.legend(handles=legend_els, facecolor="#333", labelcolor="white",
               fontsize=10, loc="upper center", ncol=4,
               framealpha=0.85, bbox_to_anchor=(0.5, 0.97))
 
    fig.suptitle("Shot Map — FRA vs DEN (WC MD2 2022)",
                 color="white", fontsize=14, weight="bold", y=1.04)
 
    plt.tight_layout(rect=[0, 0, 1, 0.96])
    out = f"{OUT_DIR}/shot_map.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
