def plot_chance_creation(df):
    print("[4/6] Chance creation map...")
 
    # After load_and_flatten: France always attacks right (+x), Denmark left (-x).
    # Fra positive opps: homeTeam==True, ball must be on France's attacking side (>= 0)
    # Den positive opps: homeTeam==False, ball AND end must be on Denmark's attacking side (<= 0)
    # Fra negative opps: homeTeam==False (Denmark in possession), no extra coord filter needed
    # Den negative opps: homeTeam==True (France in possession), ball must be on France's side (>= 0)
 
    fra_pos = df[
        df["opportunityType"].isin(["C", "H", "D"]) &
        (df["homeTeam"] == True) &
        df["ball_x"].notna() &
        (df["ball_x"] >= 0)
    ].copy()
 
    den_pos = df[
        df["opportunityType"].isin(["C", "H", "D"]) &
        (df["homeTeam"] == False) &
        df["ball_x"].notna() &
        (df["ball_x"] <= 0)
    ].copy()
    den_pos = den_pos[
        den_pos["end_x"].isna() | (den_pos["end_x"] <= 0)
    ].copy()
 
    fra_neg = df[
        df["opportunityType"].isin(["N", "P"]) &
        (df["homeTeam"] == False) &
        df["ball_x"].notna()
    ].copy()
 
    den_neg = df[
        df["opportunityType"].isin(["N", "P"]) &
        (df["homeTeam"] == True) &
        df["ball_x"].notna() &
        (df["ball_x"] >= 0)
    ].copy()
    den_neg = den_neg[
    den_neg["end_x"].isna() | (den_neg["end_x"] <= 0)
    ].copy()
 
    goals = df[df["shotOutcome"] == "G"].copy()
 
    counts = {
        "FRA_C": len(fra_pos[fra_pos["opportunityType"] == "C"]),
        "FRA_H": len(fra_pos[fra_pos["opportunityType"] == "H"]),
        "FRA_D": len(fra_pos[fra_pos["opportunityType"] == "D"]),
        "DEN_C": len(den_pos[den_pos["opportunityType"] == "C"]),
        "DEN_H": len(den_pos[den_pos["opportunityType"] == "H"]),
        "DEN_D": len(den_pos[den_pos["opportunityType"] == "D"]),
    }
    fra_neg_p = len(fra_neg[fra_neg["opportunityType"] == "P"])
    fra_neg_n = len(fra_neg[fra_neg["opportunityType"] == "N"])
    den_neg_n = len(den_neg[den_neg["opportunityType"] == "N"])
    den_neg_p = len(den_neg[den_neg["opportunityType"] == "P"])
 
    print(f"  France opportunities  — C:{counts['FRA_C']}  H:{counts['FRA_H']}  D:{counts['FRA_D']}")
    print(f"  Denmark opportunities — C:{counts['DEN_C']}  H:{counts['DEN_H']}  D:{counts['DEN_D']}")
    print(f"  Neg → France benefit  N:{fra_neg_n}  P:{fra_neg_p}")
    print(f"  Neg → Denmark benefit N:{den_neg_n}  P:{den_neg_p}")
 
    fig, ax = plt.subplots(figsize=(18, 11), facecolor="#1a1a1a")
    draw_pitch(ax)
    patches = []
 
    EVENT_LINESTYLE = {"PA": "-", "CR": "--", "CH": ":", "CL": "-."}
    OPP_END_SIZE    = {"C": 300, "H": 150, "D": 80}
    OPP_END_MARKER  = {"C": "*", "H": "o", "D": "o"}
 
    def draw_opportunity_arrows(sub, col, alpha_arrow=0.6, alpha_dot=0.9):
        for _, row in sub.iterrows():
            x1, y1 = row["ball_x"], row["ball_y"]
            x2 = row["end_x"] if pd.notna(row.get("end_x")) else x1
            y2 = row["end_y"] if pd.notna(row.get("end_y")) else y1
            evt = row.get("possEventType") or "PA"
            opp = row["opportunityType"]
            ls  = EVENT_LINESTYLE.get(evt, "-")
 
            ax.annotate("",
                xy=(x2, y2), xytext=(x1, y1),
                arrowprops=dict(
                    arrowstyle="-|>", color=col, lw=1.3,
                    linestyle=ls, mutation_scale=10, alpha=alpha_arrow,
                ),
                zorder=4)
            ax.scatter(x1, y1, c=col, s=20, alpha=0.45, zorder=5, edgecolors="none")
            ax.scatter(x2, y2, c=col,
                       s=OPP_END_SIZE.get(opp, 80),
                       marker=OPP_END_MARKER.get(opp, "o"),
                       alpha=alpha_dot, zorder=6,
                       edgecolors="white" if opp == "C" else "none",
                       linewidths=1.2 if opp == "C" else 0)
 
    # France-benefiting positives
    for otype, key, col in [
        ("C", "FRA_C", "#ff3333"),
        ("H", "FRA_H", "#ff8800"),
        ("D", "FRA_D", "#ffff00"),
    ]:
        sub = fra_pos[fra_pos["opportunityType"] == otype]
        if sub.empty:
            continue
        draw_opportunity_arrows(sub, col)
        lbl = {"C": "Chance Created", "H": "Half Chance", "D": "Dangerous"}[otype]
        patches.append(mpatches.Patch(color=col, label=f"FRA {lbl} (n={counts[key]})"))
 
    # France-benefiting negatives
    for otype, col, lbl in [
        ("N", "#ff3333", f"FRA Neg Chance via DEN error (n={fra_neg_n})"),
        ("P", "#ff8800", f"FRA Neg Dangerous via DEN error (n={fra_neg_p})"),
    ]:
        sub = fra_neg[fra_neg["opportunityType"] == otype]
        if sub.empty:
            continue
        draw_opportunity_arrows(sub, col, alpha_arrow=0.35, alpha_dot=0.55)
        patches.append(mpatches.Patch(color=col, label=lbl))
 
    # Denmark-benefiting positives
    for otype, key, col in [
        ("C", "DEN_C", "#cc00cc"),
        ("H", "DEN_H", "#9933ff"),
        ("D", "DEN_D", "#4488ff"),
