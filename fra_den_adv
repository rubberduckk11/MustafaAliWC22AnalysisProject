        f"{team_label}  —  {n} shots  |  {goals} goals  |  "
        f"{on_tgt} on target  |  {blocked} blocked  |  {off_tgt} off target\n"
        f"Headers: {headers}   Foot: {foot}   Under pressure: {pressed}/{n}",
        color="white", fontsize=11, weight="bold", pad=8,
