            continue
        grp = outcome_group(s["shotOutcome"])
        col_h, marker, size, _, lw = OUTCOME_STYLE[grp]
        ax_pitch.scatter(bx, by, c=col_h, s=size, marker=marker,
                         zorder=6, alpha=0.93,
                         edgecolors="white", linewidths=lw)
        player = (s.get("shooter") or "").split()[-1]
        clock  = s.get("formattedClock", "")
        offset_y = 1.8 if by >= 0 else -1.8
        ax_pitch.text(bx, by + offset_y, f"{player}\n{clock}",
                      fontsize=6, color="white", alpha=0.75,
                      ha="center",
                      va="bottom" if by >= 0 else "top",
                      zorder=7)
 
    n        = len(team_df)
