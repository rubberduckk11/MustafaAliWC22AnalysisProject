LINE_COLORS = {
    "D":   ("#ff4444", "Defense only"),
    "M":   ("#ffaa00", "Midfield only"),
    "MD":  ("#ff6600", "Mid + Defense"),
    "A":   ("#44ff44", "Attack only"),
