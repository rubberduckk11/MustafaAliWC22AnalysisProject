# 8.  MBAPPE EVENT ANALYSIS
# ════════════════════════════════════════════════════════════
def plot_mbappe_event_analysis(df):
    print("[6/6] Mbappe event-level analysis...")
 
    france_events = df[df["homeTeam"] == True].copy()
    MBAPPE_J      = "10"
 
    closest_dists, closest_jerseys, mbappe_xs, mbappe_ys = [], [], [], []
    for _, row in france_events.iterrows():
        hp     = row["_home_players"]
        ap     = row["_away_players"]
        mbappe = hp.get(MBAPPE_J)
        if not mbappe:
            continue
        mx = mbappe.get("x", 0)
        my = mbappe.get("y", 0)
        if str(row["period"]) == "2":
            mx, my = -mx, -my
 
        min_dist, min_j = 999, None
        for jnum, p in ap.items():
            ax_ = p.get("x", 0)
            ay_ = p.get("y", 0)
            if str(row["period"]) == "2":
                ax_, ay_ = -ax_, -ay_
            d = np.sqrt((mx - ax_)**2 + (my - ay_)**2)
            if d < min_dist:
                min_dist = d
                min_j    = jnum
        closest_dists.append(min_dist)
        closest_jerseys.append(min_j)
        mbappe_xs.append(mx)
        mbappe_ys.append(my)
 
    if not closest_dists:
        print("  No Mbappe data found.")
        return
 
    mdf = pd.DataFrame({
        "dist":   closest_dists,
        "jersey": closest_jerseys,
        "x":      mbappe_xs,
        "y":      mbappe_ys,
    })
 
    fig, axes = plt.subplots(1, 2, figsize=(16, 7), facecolor="#1a1a1a")
    ax = axes[0]
    draw_pitch(ax)
    sc = ax.scatter(mdf["x"], mdf["y"], c=mdf["dist"],
                    cmap="RdYlGn", vmin=0, vmax=20,
                    s=15, alpha=0.6, zorder=4)
    cb = fig.colorbar(sc, ax=ax, fraction=0.025, pad=0.02)
    cb.set_label("Distance to closest defender (m)", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
    ax.set_title("Mbappé Position x Defender Distance\n"
                 "(Green = space, Red = tight marking)",
                 color="white", fontsize=11, weight="bold")
 
    ax2 = axes[1]
    ax2.set_facecolor("#1a1a1a")
    jcounts  = Counter(closest_jerseys)
    sorted_j = sorted(jcounts.items(), key=lambda x: x[1], reverse=True)[:10]
    labels   = [DEN_JERSEY_NAMES.get(j, f"#{j}") for j, _ in sorted_j]
    counts   = [c for _, c in sorted_j]
    total    = sum(jcounts.values())
    pcts     = [100 * c / total for c in counts]
 
    bars = ax2.barh(labels[::-1], counts[::-1],
                    color="#1f77b4", alpha=0.85,
                    edgecolor="#555", linewidth=0.5)
    for bar, pct in zip(bars, pcts[::-1]):
        ax2.text(bar.get_width() + 3,
                 bar.get_y() + bar.get_height() / 2,
                 f"{pct:.1f}%", va="center", color="white", fontsize=9)
 
    ax2.set_xlabel("Events as closest defender to Mbappé",
                   color="white", fontsize=10)
    ax2.set_title("Who Marked Mbappé Most?\n(event-level snapshots)",
                  color="white", fontsize=11, weight="bold")
    ax2.tick_params(colors="white")
    plt.setp(ax2.get_yticklabels(), color="white", fontsize=9)
    plt.setp(ax2.get_xticklabels(), color="white")
    for spine in ax2.spines.values():
        spine.set_edgecolor("#555")
 
    pct_tight = 100 * (mdf["dist"] <= 5).mean()
    ax2.text(0.98, 0.05,
             f"Mean dist: {mdf['dist'].mean():.1f}m\n"
             f"Within 5m: {pct_tight:.1f}% of events",
             transform=ax2.transAxes, ha="right", va="bottom",
             color="#cccccc", fontsize=9,
             bbox=dict(facecolor="#333", edgecolor="#555", alpha=0.8, pad=5))
 
    fig.suptitle("Mbappé Defensive Attention — Event-Level Analysis",
                 color="white", fontsize=13, weight="bold", y=1.01)
    plt.tight_layout()
 
    out = f"{OUT_DIR}/mbappe_event_analysis.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
