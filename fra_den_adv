            plt.setp(ax_bar.get_xticklabels(), color="white")
            plt.setp(ax_bar.get_yticklabels(), color="white")
            for spine in ax_bar.spines.values():
                spine.set_edgecolor("#555")
        ax_bar.set_title(f"{team_label} — Set Piece Outcomes",
                         color="white", fontsize=10, weight="bold", pad=6)
 
        # ── Panel 3: Detailed table ───────────────────────────────────────────
        ax_tbl = fig.add_subplot(gs[row_i, 2])
        ax_tbl.set_facecolor("#1a1a1a")
        ax_tbl.axis("off")
 
        sorted_sp = team_df.sort_values("startGameClock").reset_index(drop=True)
        col_headers = ["Time", "Type", "Event", "Outcome", "Opportunity"]
        col_xs      = [0.0,    0.16,   0.33,    0.52,      0.74]
        header_y    = 0.97
        row_h       = 0.88 / max(len(sorted_sp), 1)
 
        for hdr, x in zip(col_headers, col_xs):
            ax_tbl.text(x, header_y, hdr,
                        transform=ax_tbl.transAxes,
                        fontsize=8.5, color="white", weight="bold",
                        va="top", ha="left", fontfamily="monospace")
        ax_tbl.plot([0, 1], [header_y - 0.02, header_y - 0.02],
                    color="#555", lw=1, transform=ax_tbl.transAxes)
 
        for ri, (_, row) in enumerate(sorted_sp.iterrows()):
            y = header_y - 0.04 - ri * row_h
            sp_type  = SETPIECE_LABEL.get(row.get("setpieceType",""), "")
            evt_type = row.get("possEventType","")
            outcome  = row.get("passOutcome") or row.get("crossOutcome") or "—"
            opp      = OPP_LABEL.get(row.get("opportunityType",""), "—")
            opp_col  = OPP_COLOURS.get(row.get("opportunityType",""), "white")
            ct       = CROSS_TYPE.get(row.get("crossType",""), "")
            evt_lbl  = {"PA":"Pass","CR":f"Cross ({ct})","SH":"Shot","CL":"Clear"}.get(evt_type, evt_type)
 
            bg = "#222222" if ri % 2 == 0 else "#1a1a1a"
            ax_tbl.add_patch(plt.Rectangle(
                (0, y - row_h*0.85), 1, row_h*0.92,
                transform=ax_tbl.transAxes,
                facecolor=bg, edgecolor="none", zorder=0))
 
            vals  = [row.get("formattedClock",""), sp_type, evt_lbl,
                     OUTCOME_LABEL.get(outcome, outcome), opp]
            cols  = ["white","white","white","white", opp_col]
            bolds = [False, False, False, False,
                     row.get("opportunityType") in ['C','H','D']]
 
            for val, x, col, bold in zip(vals, col_xs, cols, bolds):
                ax_tbl.text(x, y, val,
