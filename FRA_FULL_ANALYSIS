# PER-GAME 8 — MBAPPÉ DEFENDER DISTANCE
# ════════════════════════════════════════════════════════════
def plot_mbappe_event_analysis(df, game_id, out_dir, france_is_home):
    meta = GAME_META[game_id]; MBAPPE_J = "10"
    fe = df[df["is_france"] & ~df["is_pen_shootout"]].copy()

    dists, jerseys, mxs, mys = [], [], [], []
    for _, row in fe.iterrows():
        hp = row["_home_players"]; ap = row["_away_players"]
        mb = hp.get(MBAPPE_J) if france_is_home else ap.get(MBAPPE_J)
        defenders = ap if france_is_home else hp
        if not mb: continue
        period = str(row.get("period",""))
        mx = mb.get("x",0); my = mb.get("y",0)
        if period=="2": mx,my = -mx,-my
        if not france_is_home: mx,my = -mx,-my

        min_d, min_j = 999, None
        for jnum, p in defenders.items():
            ax_ = p.get("x",0); ay_ = p.get("y",0)
            if period=="2": ax_,ay_ = -ax_,-ay_
            if not france_is_home: ax_,ay_ = -ax_,-ay_
            d = np.sqrt((mx-ax_)**2+(my-ay_)**2)
            if d < min_d: min_d = d; min_j = jnum
        dists.append(min_d); jerseys.append(min_j)
        mxs.append(mx); mys.append(my)

    if not dists: print("  No Mbappé defender data"); return
    mdf = pd.DataFrame({"dist":dists,"jersey":jerseys,"x":mxs,"y":mys})

    fig, axes = plt.subplots(1,2, figsize=(16,7), facecolor="#1a1a1a")
    ax = axes[0]; draw_pitch(ax)
    sc = ax.scatter(mdf["x"], mdf["y"], c=mdf["dist"], cmap="RdYlGn",
                    vmin=0, vmax=20, s=15, alpha=0.6, zorder=4)
    cb = fig.colorbar(sc, ax=ax, fraction=0.025, pad=0.02)
    cb.set_label("Distance to closest defender (m)", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
    pct_t = 100*(mdf["dist"]<=5).mean()
    ax.set_title(f"Mbappé Position × Defender Distance\n"
                 f"{meta['stage']}: {meta['label']}\n"
                 f"Mean {mdf['dist'].mean():.1f}m  |  Within 5m: {pct_t:.1f}%",
                 color="white", fontsize=11, weight="bold")

    ax2 = axes[1]; ax2.set_facecolor("#1a1a1a")
    jc = Counter(jerseys)
    top_j = sorted(jc.items(), key=lambda x: x[1], reverse=True)[:10]
    lbls  = [f"#{j}" for j,_ in top_j]; cnts = [c for _,c in top_j]
    total = sum(jc.values())
    bars = ax2.barh(lbls[::-1], cnts[::-1], color="#1f77b4",
                    alpha=0.85, edgecolor="#555", linewidth=0.5)
    for bar, cnt in zip(bars, cnts[::-1]):
        ax2.text(bar.get_width()+1, bar.get_y()+bar.get_height()/2,
                 f"{100*cnt/total:.1f}%", va="center", color="white", fontsize=9)
    ax2.set_xlabel("Events as closest defender", color="white", fontsize=10)
    ax2.set_title(f"Who Marked Mbappé Most?\n{meta['stage']}: {meta['label']}",
                  color="white", fontsize=11, weight="bold")
    ax2.tick_params(colors="white")
    plt.setp(ax2.get_yticklabels(), color="white", fontsize=9)
    plt.setp(ax2.get_xticklabels(), color="white")
    for spine in ax2.spines.values(): spine.set_edgecolor("#555")

    fig.suptitle(f"Mbappé Defensive Attention — {meta['stage']}: {meta['label']}",
                 color="white", fontsize=13, weight="bold", y=1.01)
    plt.tight_layout()
    fig.savefig(f"{out_dir}/08_mbappe_defender_dist_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 08_mbappe_defender_dist_{game_id}.png")


