# PER-GAME 1 — PASSING NETWORK
# ════════════════════════════════════════════════════════════
def plot_passing_network(df, game_id, out_dir):
    meta = GAME_META[game_id]
    # exclude penalty shootout rows
    df = df[~df["is_pen_shootout"]]

    fp = df[df["is_france"] & (df["possEventType"]=="PA") &
            df["passer"].notna() & df["ball_x"].notna()].copy()
    if fp.empty: return

    node_pos = (fp.groupby("passer")[["ball_x","ball_y"]]
                  .mean().rename(columns={"ball_x":"x","ball_y":"y"}))
    comp         = fp[fp["passOutcome"]=="C"]
    edge_counts  = defaultdict(int)
    all_attempts = defaultdict(int)
    for _, row in comp.iterrows():
        if pd.notna(row["receiver"]):
            edge_counts[(row["passer"], row["receiver"])] += 1
    for _, row in fp.iterrows():
        if pd.notna(row["target"]):
            all_attempts[(row["passer"], row["target"])] += 1

    fig = plt.figure(figsize=(20,9), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(1,2, width_ratios=[3,1], wspace=0.05)
    ax  = fig.add_subplot(gs[0,0])
    ax_t= fig.add_subplot(gs[0,1])
    draw_pitch(ax)

    max_e = max(edge_counts.values(), default=1)
    for (pa, re), count in edge_counts.items():
        if count < 2 or pa not in node_pos.index or re not in node_pos.index: continue
        x1,y1 = node_pos.loc[pa, ["x","y"]]
        x2,y2 = node_pos.loc[re, ["x","y"]]
        c = count / max(all_attempts.get((pa,re), 1), 1)
        ax.annotate("", xy=(x2,y2), xytext=(x1,y1),
                    arrowprops=dict(arrowstyle="-|>", color=plt.cm.RdYlGn(c),
                                   lw=0.8+5.5*(count/max_e), mutation_scale=14, alpha=0.85))

    pc = fp.groupby("passer").size()
    for player, (px, py) in node_pos.iterrows():
        n = pc.get(player, 1)
        ax.scatter(px, py, s=150+700*(n/pc.max()), c="#1f77b4",
                   zorder=5, edgecolors="white", linewidths=2)
        ax.text(px, py+3, SHORT_NAME.get(player, player.split()[-1]),
                ha="center", va="bottom", fontsize=8, color="white",
                weight="bold", zorder=6)

    sm = ScalarMappable(cmap="RdYlGn", norm=Normalize(0,1)); sm.set_array([])
    cb = fig.colorbar(sm, ax=ax, fraction=0.022, pad=0.02)
    cb.set_label("Pass completion rate", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
    ax.set_title(f"France Passing Network — {meta['stage']}: {meta['label']}",
                 color="white", fontsize=13, weight="bold", pad=10)
    ax.text(0, -37,
            "Nodes=avg passing position | Size=pass volume | Arrow width=frequency | Colour=completion%",
            ha="center", color="#aaaaaa", fontsize=7.5)

    # Side table
    ax_t.set_facecolor("#1a1a1a"); ax_t.axis("off")
    rows_t = []
    for (p,r) in set(edge_counts) | set(all_attempts):
        c2 = edge_counts.get((p,r), 0); a = all_attempts.get((p,r), c2)
        if a < 2: continue
        rows_t.append((p, r, c2, a))
    rows_t.sort(key=lambda t: (-t[2], -t[3])); rows_t = rows_t[:20]
    ax_t.text(0.5,0.985, f"Top {len(rows_t)} pass combos",
              transform=ax_t.transAxes, ha="center", va="top",
              color="white", fontsize=12, weight="bold")
    ax_t.text(0.02,0.945,"From → To", transform=ax_t.transAxes,
              ha="left", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_t.text(0.78,0.945,"Comp/Att", transform=ax_t.transAxes,
              ha="right", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_t.text(0.99,0.945,"%", transform=ax_t.transAxes,
              ha="right", va="top", color="#aaaaaa", fontsize=9, weight="bold")
    ax_t.plot([0.02,0.99],[0.93,0.93], transform=ax_t.transAxes, color="#555", lw=0.8)
    if rows_t:
        y_top, y_bot = 0.91, 0.02
        step = (y_top-y_bot) / max(len(rows_t), 1)
        for idx, (p,r,c2,a) in enumerate(rows_t):
            y = y_top - idx*step; pct = 100*c2/max(a,1)
            ax_t.text(0.02, y, f"{SHORT_NAME.get(p,p.split()[-1])} → {SHORT_NAME.get(r,r.split()[-1])}",
                      transform=ax_t.transAxes, ha="left", va="top", color="white", fontsize=8.5)
            ax_t.text(0.78, y, f"{c2}/{a}", transform=ax_t.transAxes,
                      ha="right", va="top", color="white", fontsize=8.5)
            ax_t.text(0.99, y, f"{pct:.0f}", transform=ax_t.transAxes,
                      ha="right", va="top", color=plt.cm.RdYlGn(c2/max(a,1)),
                      fontsize=8.5, weight="bold")

    fig.savefig(f"{out_dir}/01_passing_network_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 01_passing_network_{game_id}.png")


