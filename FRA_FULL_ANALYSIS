# ════════════════════════════════════════════════════════════
def plot_press_map(df, game_id, out_dir):
    meta = GAME_META[game_id]; opp = meta["opponent"]
    df = df[~df["is_pen_shootout"]]

    dp = df[~df["is_france"] & df["pressureType"].isin(["P","A"]) & df["ball_x"].notna()]
    fp = df[ df["is_france"] & df["pressureType"].isin(["P","A"]) & df["ball_x"].notna()]

    fig, axes = plt.subplots(1,2, figsize=(20,8), facecolor="#1a1a1a")
    for ax, data, full, title, sub in [
        (axes[0], dp, dp[dp["pressureType"]=="P"],
         f"{opp} Pressure on France\n(France in possession)",
         f"Where France were pressured by {opp}"),
        (axes[1], fp, fp[fp["pressureType"]=="P"],
         f"France Pressure on {opp}\n({opp} in possession)",
         f"Where France pressed {opp}"),
    ]:
        draw_pitch(ax)
        xs, ys = data["ball_x"].values, data["ball_y"].values
        if len(xs):
            if len(xs) > 0:
                ax.hist2d(xs, ys, bins=[26, 17], cmap="hot", alpha=0.70,
                          range=[[-52.5,52.5],[-34,34]], zorder=2)
        ax.scatter(full["ball_x"], full["ball_y"], c="cyan", s=20,
                   alpha=0.55, zorder=4, label=f"Pressured (n={len(full)})")
        ax.legend(facecolor="#333", labelcolor="white", fontsize=8, loc="upper left")
        ax.set_title(title, color="white", fontsize=11, weight="bold", pad=6)
        ax.text(0, 38, sub, ha="center", color="#aaaaaa", fontsize=8)

    sm = ScalarMappable(cmap="hot"); sm.set_array([])
    cb = fig.colorbar(sm, ax=axes, fraction=0.015, pad=0.02)
    cb.set_label("Pressure density", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
    fig.suptitle(f"Pressure Maps — {meta['stage']}: {meta['label']}  |  France attacks →",
                 color="white", fontsize=13, weight="bold", y=1.02)
    fig.savefig(f"{out_dir}/02_press_map_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 02_press_map_{game_id}.png")


