# COMPARATIVE 3 — PLAYER GRADE HEATMAP
# ════════════════════════════════════════════════════════════
def plot_comparative_player_grades(all_dfs, out_dir):
    print("  -> COMP_03 player grades heatmap...")
    GMAP = {"passerGrade":"passer","receiverGrade":"receiver",
            "shooterGrade":"shooter","dribbleGrade":"dribbler",
            "challengerGrade":"challenger","carrierGrade":"carrier"}

    all_players = set()
    game_pg     = {}
    game_pn     = {}
    for game_id in GAME_ORDER:
        df = all_dfs[game_id][~all_dfs[game_id]["is_pen_shootout"]]
        gg = defaultdict(list)
        for _, row in df[df["is_france"]].iterrows():
            for gc, pc in GMAP.items():
                g = row.get(gc); p = row.get(pc)
                if pd.isna(g) or not p or p not in FRANCE_PLAYERS: continue
                gg[p].append(float(g)); all_players.add(p)
        game_pg[game_id] = {p: float(np.mean(v)) for p,v in gg.items()}
        game_pn[game_id] = {p: len(v) for p,v in gg.items()}

    players = sorted(all_players, key=lambda p: -np.nanmean(
        [game_pg[g].get(p,np.nan) for g in GAME_ORDER]))

    matrix = np.full((len(players), len(GAME_ORDER)), np.nan)
    n_mat  = np.zeros((len(players), len(GAME_ORDER)), dtype=int)
    for pi,p in enumerate(players):
        for gi,g in enumerate(GAME_ORDER):
            matrix[pi,gi] = game_pg[g].get(p, np.nan)
            n_mat[pi,gi]  = game_pn[g].get(p, 0)

    game_labels = [f"{GAME_META[g]['label_short']}\n{GAME_META[g]['stage']}"
                   for g in GAME_ORDER]

    fig, ax = plt.subplots(figsize=(24, max(10, len(players)*0.55+3)),
                           facecolor="#1a1a1a")
    ax.set_facecolor("#1a1a1a")
    im = ax.imshow(matrix, cmap="RdYlGn", vmin=-0.15, vmax=0.15, aspect="auto")
    cbar = fig.colorbar(im, ax=ax, fraction=0.03, pad=0.02)
    cbar.set_label("Avg PFF Grade", color="white", fontsize=10)
    plt.setp(cbar.ax.yaxis.get_ticklabels(), color="white")
    cbar.ax.yaxis.set_tick_params(color="white")

    ax.set_xticks(range(len(GAME_ORDER)))
    ax.set_xticklabels(game_labels, rotation=20, ha="right", color="white", fontsize=9)
    ax.set_yticks(range(len(players)))
    ax.set_yticklabels(players, color="white", fontsize=10)

    for pi in range(len(players)):
        for gi in range(len(GAME_ORDER)):
            v = matrix[pi,gi]; n = n_mat[pi,gi]
            if not np.isnan(v):
                tc  = "black" if abs(v) < 0.08 else "white"
                lbl = f"{v:+.2f}" + (" ⚠" if n < 10 else "")
                ax.text(gi, pi, lbl, ha="center", va="center",
                        fontsize=7.5, color=tc, weight="bold")
            else:
                ax.text(gi, pi, "—", ha="center", va="center",
                        fontsize=9, color="#555555")

    for gi, g in enumerate(GAME_ORDER):
        rc = RESULT_COLOR[GAME_META[g]["result"]]
        ax.add_patch(plt.Rectangle((gi-0.5,-0.5), 1, 0.45, color=rc, alpha=0.5, zorder=3))
        ax.text(gi, -0.28, GAME_META[g]["result"], ha="center", va="center",
                color=rc, fontsize=9, weight="bold")

    ax.set_xlim(-0.5, len(GAME_ORDER)-0.5)
    ax.set_ylim(-0.75, len(players)-0.3)
    for spine in ax.spines.values(): spine.set_edgecolor("#555")
    ax.tick_params(colors="white")
    ax.set_title("France Player PFF Grades — All 7 WC 2022 Matches\n"
                 "Red=below expected | Green=above expected | —=no data | "
                 "⚠=fewer than 10 obs | pen shootout excluded",
                 color="white", fontsize=13, weight="bold", pad=12)
    plt.tight_layout()
    fig.savefig(f"{out_dir}/COMP_03_player_grades_heatmap.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"     -> COMP_03_player_grades_heatmap.png")


