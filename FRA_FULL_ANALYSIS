# PER-GAME 6 — PLAYER GRADES
# ════════════════════════════════════════════════════════════
def plot_player_grades(df, game_id, out_dir):
    meta = GAME_META[game_id]
    df = df[~df["is_pen_shootout"]]

    GMAP = {
        "passerGrade":"passer","receiverGrade":"receiver","targetGrade":"target",
        "shooterGrade":"shooter","dribbleGrade":"dribbler",
        "challengerGrade":"challenger","carrierGrade":"carrier",
        "ballCarrierGrade":"ballCarrier",
    }
    grade_rows = []
    for _, row in df[df["is_france"]].iterrows():
        for gc, pc in GMAP.items():
            g = row.get(gc); p = row.get(pc)
            if pd.isna(g) or not p or p not in FRANCE_PLAYERS: continue
            grade_rows.append({"player": p, "grade": float(g)})
    if not grade_rows: print("  No grade data"); return

    gdf = pd.DataFrame(grade_rows)
    summary = (gdf.groupby("player")
                  .agg(avg_grade=("grade","mean"), n=("grade","count"))
                  .reset_index()
                  .sort_values("avg_grade", ascending=True))

    outliers = summary[summary["n"] < 10]["player"].tolist()
    fig, ax  = plt.subplots(figsize=(13, max(7, len(summary)*0.6+2)),
                            facecolor="#1a1a1a")
    ax.set_facecolor("#1a1a1a")
    colors = ["#ff4444" if g<-0.005 else "#44ff44" if g>0.005 else "#888888"
              for g in summary["avg_grade"]]
    bars = ax.barh(range(len(summary)), summary["avg_grade"],
                   color=colors, alpha=0.85, edgecolor="#555",
                   linewidth=0.5, height=0.65)

    ylabels = [row["player"] + (" ⚠" if row["player"] in outliers else "")
               for _, row in summary.iterrows()]
    ax.set_yticks(range(len(summary)))
    ax.set_yticklabels(ylabels, fontsize=10, color="white")
    ax.set_ylim(-0.7, len(summary)-0.3)
    xmax = summary["avg_grade"].abs().max()
    ax.set_xlim(-xmax*1.6, xmax*1.6)
    ax.axvline(0, color="white", lw=1.2, alpha=0.7)

    for bar, (_, row) in zip(bars, summary.iterrows()):
        x = bar.get_width()
        offset = xmax*0.04 if x >= 0 else -xmax*0.04
        ax.text(x+offset, bar.get_y()+bar.get_height()/2,
                f"{row['avg_grade']:+.3f}  (n={int(row['n'])})",
                va="center", ha="left" if x>=0 else "right",
                color="white", fontsize=9)

    if outliers:
        ax.text(0.99, 0.01, "⚠ = fewer than 10 grade obs — treat with caution",
                transform=ax.transAxes, ha="right", va="bottom",
                color="#ffaa00", fontsize=8, style="italic")

    ax.set_xlabel("Average PFF Grade  (−2 to +2,  0=expected)",
                  color="white", fontsize=10)
    ax.set_title(f"France Player Grades — {meta['stage']}: {meta['label']}",
                 color="white", fontsize=12, weight="bold", pad=12)
    ax.tick_params(colors="white")
    plt.setp(ax.get_xticklabels(), color="white")
    for spine in ax.spines.values(): spine.set_edgecolor("#555")

    patches = [mpatches.Patch(color="#44ff44", label="Above expected"),
               mpatches.Patch(color="#888888", label="Expected (~0)"),
               mpatches.Patch(color="#ff4444", label="Below expected")]
    ax.legend(handles=patches, facecolor="#333", labelcolor="white",
              fontsize=9, loc="lower right")
    plt.tight_layout()
    fig.savefig(f"{out_dir}/06_player_grades_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 06_player_grades_{game_id}.png")


