def plot_team_shape(df, game_id, out_dir, france_is_home):
    """
    Plot France's average outfield player positions for each tactical phase
    of the match. Phases are defined by goals AND substitutions — every big
    moment creates a new phase boundary.

    For each game this produces two files:
      11a_shape_timeline_XXXX.png  — annotated match timeline
      11b_shape_phases_XXXX.png    — one pitch panel per phase
    """
    meta = GAME_META[game_id]
    opp  = meta["opponent"]

    # Load raw JSON so we have the player tracking coordinates
    path = f"{DATA_DIR}/{FILE_MAP[game_id]}"
    with open(path, encoding="utf-8") as f:
        raw_full = json.load(f)

    # Determine match end clock (last event clock)
    end_clock = 0
    for r in raw_full:
        ge = r.get("gameEvents") or {}
        pe = r.get("possessionEvents") or {}
        if pe.get("nonEvent"): continue
        c = ge.get("startGameClock", 0) or 0
        if c > end_clock:
            end_clock = c
    # Cap Argentina at end of ET (pen shootout already tagged)
    if game_id == "10517":
        end_clock = min(end_clock, 120 * 60)

    # ── Extract all big moments ───────────────────────────────────────────────
    moments = extract_big_moments(raw_full, game_id, france_is_home)
    if not moments:
        print(f"  No big moments found for {game_id}")
        return

    # ── Build phase list ──────────────────────────────────────────────────────
    # Each phase = (start_clock, end_clock, label, boundary_moment_or_None)
    # Phase 0 always starts at 0. Each moment creates the boundary for next phase.
    # Consecutive subs within 90 seconds are merged into one boundary.

    # Collapse same-minute batch events into single boundary events
    boundaries = []
    for m in moments:
        if boundaries and abs(m["clock"] - boundaries[-1]["clock"]) <= 90 \
                and m["type"] == "sub" and boundaries[-1]["type"] == "sub":
            # Merge into existing boundary — append sub details
            boundaries[-1]["label"] += f"\n+ {m['label'].split(chr(10))[-1]}"
            boundaries[-1]["subs"].append(m)
        else:
            entry = dict(m)
            entry["subs"] = [m] if m["type"] == "sub" else []
            boundaries.append(entry)

    phases = []
    phase_starts = [0] + [b["clock"] for b in boundaries]
    phase_ends   = [b["clock"] for b in boundaries] + [end_clock]

    for i, (ps, pe_c, bnd) in enumerate(
            zip(phase_starts, phase_ends, [None] + boundaries)):
        # Skip zero-length phases
        if pe_c <= ps:
            continue

        start_min = ps // 60
        end_min   = pe_c // 60

        if bnd is None:
            phase_lbl = f"Phase 1: Kick-off → {end_min}'"
            dot_col   = "#aaaaaa"
        else:
            btype = bnd["type"]
            if btype in ("goal", "own_goal"):
                scorer_lbl = bnd["label"].replace("\n", " ")
                dot_col    = "#00ee44" if bnd["is_france"] else "#ff4444"
            else:
                scorer_lbl = bnd["label"].replace("\n", " ")
                dot_col    = "#4488ff" if bnd["is_france"] else "#ffaa00"
            phase_lbl = f"Phase {i+1}: After {scorer_lbl} → {end_min}'"

        phases.append({
            "start":     ps,
            "end":       pe_c,
            "label":     phase_lbl,
            "dot_color": dot_col,
            "boundary":  bnd,
            "start_min": start_min,
            "end_min":   end_min,
            "duration":  (pe_c - ps) // 60,
        })

    # ── Figure 1: Timeline ────────────────────────────────────────────────────
    match_mins = end_clock / 60
    fig_tl, ax_tl = plt.subplots(
        figsize=(max(16, match_mins * 0.22 + 2), 5), facecolor="#1a1a1a")
    ax_tl.set_facecolor("#1a1a1a")
    ax_tl.set_xlim(-2, match_mins + 3)
    ax_tl.set_ylim(-0.5, 4.5)   # taller to accommodate jitter
    ax_tl.axis("off")

    # Phase background bands
    for ph in phases:
        ax_tl.axvspan(ph["start"] / 60, ph["end"] / 60,
                      alpha=0.06, color=ph["dot_color"], zorder=0)

    # HT / ET dividers
    for div_min, div_lbl in [(45,"HT"), (90,"90'"), (105,"105'"), (120,"120'")]:
        if div_min <= match_mins:
            ax_tl.axvline(div_min, color="#555", lw=1.5, ls="--", alpha=0.8)
            ax_tl.text(div_min, 4.1, div_lbl, ha="center",
                       color="#888", fontsize=9)

    # Timeline spine
    ax_tl.axhline(1, color="#444", lw=1.5, alpha=0.6)

    # Jitter: assign vertical level based on proximity in seconds (not just minute buckets).
    # Any two moments within 120 seconds of each other get stacked.
    JITTER_WINDOW = 120   # seconds — events closer than this stack vertically
    assigned = []         # list of (clock, y_level) already placed
    def get_jitter(clock):
        level = 0
        while any(abs(clock - c) < JITTER_WINDOW and l == level for c, l in assigned):
            level += 1
        assigned.append((clock, level))
        return level

    for m in moments:
        mins  = m["clock"] / 60
        col   = m["color"]
        level = get_jitter(m["clock"])
        y_pos = 1 + level * 0.65

        ax_tl.scatter(mins, y_pos, s=200, c=col, zorder=5,
                      edgecolors="white", linewidths=1.3)
