# PER-GAME 9 — SET PIECES
# ════════════════════════════════════════════════════════════
def plot_set_pieces(df, game_id, out_dir):
    meta = GAME_META[game_id]; opp = meta["opponent"]
    df = df[~df["is_pen_shootout"]]

    SL  = {'C':'Corner','F':'Free Kick','T':'Throw In','G':'Goal Kick','P':'Penalty'}
    OL  = {'C':'Complete','D':'Intercepted','O':'Out of Play',
           'B':'Blocked','S':'Stoppage','G':'Goal','I':'Shot at Goal'}
    AL  = {'C':'Chance','H':'Half Chance','D':'Dangerous',
           'N':'Neg Chance','P':'Neg Dangerous'}
    SPC = {'C':'#ff6600','F':'#44aaff','T':'#ffff00','G':'#aaaaaa','P':'#ff3333'}
    OPC = {'C':'#ff3333','H':'#ff8800','D':'#ffff00','N':'#4488ff','P':'#9933ff'}
    CT  = {'I':'Inswinger','O':'Outswinger','D':'Drilled','F':'Floated','P':'Placed'}

    sp_df  = df[df["setpieceType"].notna() & (df["setpieceType"]!="O") &
                (df["setpieceType"]!="K")].copy()
    fra_sp = sp_df[ sp_df["is_france"]].copy()
    opp_sp = sp_df[~sp_df["is_france"]].copy()
    opp_sp[["ball_x","ball_y","end_x","end_y"]] *= -1

    fig = plt.figure(figsize=(26,16), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(2,3, width_ratios=[1.2,1,1], hspace=0.28,
                           wspace=0.12, left=0.03, right=0.97,
                           top=0.92, bottom=0.04)

    for row_i, (team_df, team_label) in enumerate([(fra_sp,"France"),(opp_sp,opp)]):
        ax_m = fig.add_subplot(gs[row_i,0])
        draw_pitch(ax_m, attack_label="attack →")
        for sp_type, colour in SPC.items():
            sub = team_df[(team_df["setpieceType"]==sp_type) & team_df["ball_x"].notna()]
            if sub.empty: continue
            ax_m.scatter(sub["ball_x"], sub["ball_y"], c=colour, s=120, zorder=5,
                         alpha=0.85, edgecolors="white", linewidths=0.8,
                         label=f"{SL.get(sp_type,sp_type)} (n={len(sub)})")
        for _, row in team_df[team_df["opportunityType"].notna() & team_df["ball_x"].notna()].iterrows():
            ax_m.scatter(row["ball_x"], row["ball_y"],
                         c=OPC.get(row["opportunityType"],"#fff"),
                         s=300, marker="*", zorder=7, edgecolors="white", linewidths=1.2)
        ax_m.legend(facecolor="#333", labelcolor="white", fontsize=7.5,
                    loc="upper left", framealpha=0.85)
        ax_m.set_title(f"{team_label} — Set Piece Locations",
                       color="white", fontsize=10, weight="bold", pad=6)

        ax_b = fig.add_subplot(gs[row_i,1]); ax_b.set_facecolor("#1a1a1a")
        type_out = {}
        for sp_type in ['C','F','T','G']:
            sub = team_df[team_df["setpieceType"]==sp_type]
            if sub.empty: continue
            outcomes = Counter()
            for _, row in sub.iterrows():
                o = row.get("passOutcome") or row.get("crossOutcome") or "?"
                outcomes[OL.get(o,o)] += 1
            type_out[SL.get(sp_type,sp_type)] = outcomes
        if type_out:
            all_oc = ['Complete','Blocked','Intercepted','Out of Play','Stoppage','Shot at Goal']
            oc_c   = ['#44ff44','#ffaa00','#ff4444','#aaaaaa','#4488ff','#ff00ff']
            ys = list(type_out.keys()); bots = [0]*len(ys)
            for oc, occ in zip(all_oc, oc_c):
                vals = [type_out[y].get(oc,0) for y in ys]
                if sum(vals)==0: continue
                ax_b.barh(ys, vals, left=bots, color=occ, alpha=0.85,
                          edgecolor="#333", linewidth=0.5, label=oc)
                for yi,(v,b) in enumerate(zip(vals,bots)):
                    if v>0: ax_b.text(b+v/2, yi, str(v), ha='center',
                                      va='center', fontsize=8, color='white', weight='bold')
                bots = [b+v for b,v in zip(bots,vals)]
            ax_b.legend(facecolor="#333", labelcolor="white", fontsize=7,
                        loc="lower right", framealpha=0.85)
            ax_b.set_xlabel("Count", color="white", fontsize=9)
            ax_b.tick_params(colors="white")
            plt.setp(ax_b.get_xticklabels(), color="white")
            plt.setp(ax_b.get_yticklabels(), color="white")
            for spine in ax_b.spines.values(): spine.set_edgecolor("#555")
        ax_b.set_title(f"{team_label} — Set Piece Outcomes",
                       color="white", fontsize=10, weight="bold", pad=6)

        ax_t = fig.add_subplot(gs[row_i,2])
        ax_t.set_facecolor("#1a1a1a"); ax_t.axis("off")
        sdf = team_df.sort_values("startGameClock").reset_index(drop=True)
        col_h = ["Time","Type","Event","Outcome","Opportunity"]
        col_x = [0.0, 0.16, 0.33, 0.52, 0.74]
        hy = 0.97; rh = 0.88/max(len(sdf),1)
        for hdr, x in zip(col_h, col_x):
            ax_t.text(x, hy, hdr, transform=ax_t.transAxes, fontsize=8.5,
                      color="white", weight="bold", va="top", ha="left",
                      fontfamily="monospace")
        ax_t.plot([0,1],[hy-0.02,hy-0.02], color="#555", lw=1,
                  transform=ax_t.transAxes)
        for ri, (_, row) in enumerate(sdf.iterrows()):
            y = hy - 0.04 - ri*rh
            spt = SL.get(row.get("setpieceType",""),"")
            evt = row.get("possEventType","")
            out = row.get("passOutcome") or row.get("crossOutcome") or "—"
            opt = AL.get(row.get("opportunityType",""),"—")
            opc = OPC.get(row.get("opportunityType",""),"white")
            ct  = CT.get(row.get("crossType",""),"")
            el  = {"PA":"Pass","CR":f"Cross({ct})","SH":"Shot","CL":"Clear"}.get(evt,evt)
            bg  = "#222222" if ri%2==0 else "#1a1a1a"
            ax_t.add_patch(plt.Rectangle((0,y-rh*0.85), 1, rh*0.92,
                           transform=ax_t.transAxes, facecolor=bg,
                           edgecolor="none", zorder=0))
            vals  = [row.get("formattedClock",""), spt, el, OL.get(out,out), opt]
            cols  = ["white","white","white","white", opc]
            bolds = [False,False,False,False,
                     row.get("opportunityType") in ['C','H','D']]
            for val, x, col, bold in zip(vals, col_x, cols, bolds):
                ax_t.text(x, y, val, transform=ax_t.transAxes, fontsize=7.8,
                          va="top", ha="left", fontfamily="monospace",
                          color=col, weight="bold" if bold else "normal", zorder=1)
        ax_t.set_xlim(0,1); ax_t.set_ylim(0,1)
        ax_t.set_title(f"{team_label} — Set Piece Detail",
                       color="white", fontsize=10, weight="bold", pad=6)

    fig.suptitle(f"Set Piece Analysis — {meta['stage']}: {meta['label']}  |  ★=Opportunity",
                 color="white", fontsize=13, weight="bold", y=0.98)
    fig.savefig(f"{out_dir}/09_set_pieces_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 09_set_pieces_{game_id}.png")


