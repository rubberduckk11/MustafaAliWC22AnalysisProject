# PER-GAME 5 — SHOT MAP
# ════════════════════════════════════════════════════════════
def plot_shot_map(df, game_id, out_dir):
    meta = GAME_META[game_id]; opp = meta["opponent"]
    # exclude penalty shootout
    df = df[~df["is_pen_shootout"]]

    shots = df[(df["possEventType"]=="SH") & df["shooter"].notna()].copy()
    fra   = shots[shots["is_france"]].copy()
    opp_s = shots[~shots["is_france"]].copy()
    opp_s[["ball_x","ball_y"]] *= -1

    OSTYLE = {"goal":("#00ee44","*",700,2.0), "on_target":("#44aaff","o",280,1.3),
              "blocked":("#ffaa00","D",220,1.0), "off_target":("#ff4444","X",220,0.8)}
    RLBL   = {"goal":"GOAL","on_target":"On Target","blocked":"Blocked","off_target":"Off Target"}
    RCOL   = {"goal":"#00ee44","on_target":"#44aaff","blocked":"#ffaa00","off_target":"#ff4444"}
    BODY   = {"R":"Right","L":"Left","HE":"Header","RT":"R.Thigh","LT":"L.Thigh"}
    SNAT   = {"P":"Power","A":"Accurate","F":"Flick","T":"Toe"}
    PLBL   = {"P":"Pressured","A":"Press Att.","L":"Lane","N":"Free"}

    def og(o):
        if o=="G": return "goal"
        if o in ("S","F"): return "on_target"
        if o=="B": return "blocked"
        return "off_target"

    def _draw(tdf, tlabel, fname):
        fig = plt.figure(figsize=(26,10), facecolor="#1a1a1a")
        gs  = fig.add_gridspec(1,2, width_ratios=[1,1.3], wspace=0.06,
                               left=0.01, right=0.99, top=0.88, bottom=0.04)
        ax_p = fig.add_subplot(gs[0,0]); ax_t = fig.add_subplot(gs[0,1])
        draw_attacking_half(ax_p)

        for _, s in tdf.iterrows():
            bx, by = s["ball_x"], s["ball_y"]
            if pd.isna(bx) or pd.isna(by): continue
            col, mk, sz, lw = OSTYLE[og(s["shotOutcome"])]
            ax_p.scatter(bx, by, c=col, s=sz, marker=mk, zorder=6,
                         alpha=0.93, edgecolors="white", linewidths=lw)
            pl = (s.get("shooter") or "").split()[-1]
            oy = 1.8 if by >= 0 else -1.8
            ax_p.text(bx, by+oy, f"{pl}\n{s.get('formattedClock','')}",
                      fontsize=6, color="white", alpha=0.75, ha="center",
                      va="bottom" if by>=0 else "top", zorder=7)

        n  = len(tdf)
        g  = len(tdf[tdf["shotOutcome"]=="G"])
        on = len(tdf[tdf["shotOutcome"].isin(["S","F"])])
        bl = len(tdf[tdf["shotOutcome"]=="B"])
        off= n - g - on - bl
        pr = len(tdf[tdf["pressureType"]=="P"])
        pen_note = "\n(Penalty shootout excluded)" if game_id=="10517" else ""
        ax_p.set_title(
            f"{tlabel} — {n} shots | {g} goals | {on} on target | "
            f"{bl} blocked | {off} off{pen_note}\nUnder pressure: {pr}/{n}",
            color="white", fontsize=11, weight="bold", pad=8)

        ax_t.set_facecolor("#1a1a1a"); ax_t.axis("off")
        sdf = tdf.sort_values("startGameClock").reset_index(drop=True)
        col_h = ["#","Time","Player","Body","Nature","Pressure","Result"]
        col_w = [0.03, 0.08, 0.18, 0.12, 0.12, 0.13, 0.11]
        xs = []; cx = 0.0
        for w in col_w: xs.append(cx); cx += w
        hy = 0.97; rh = 0.88 / max(len(sdf)+1, 1)
        for hdr, x in zip(col_h, xs):
            ax_t.text(x, hy, hdr, transform=ax_t.transAxes, fontsize=9,
                      color="white", weight="bold", va="top", ha="left",
                      fontfamily="monospace")
        ax_t.plot([0,1],[hy-0.02,hy-0.02], color="#555", lw=1,
                  transform=ax_t.transAxes)
        for ri, (_, s) in enumerate(sdf.iterrows()):
            y = hy - 0.04 - ri*rh
            grp = og(s["shotOutcome"]); rc = RCOL[grp]; rl = RLBL[grp]
            body  = BODY.get(s.get("bodyType",""),  s.get("bodyType","")  or "")
            snat  = SNAT.get(s.get("shotNature",""), s.get("shotNature","") or "")
            press = PLBL.get(s.get("pressureType",""), "—")
            bg = "#222222" if ri%2==0 else "#1a1a1a"
            ax_t.add_patch(plt.Rectangle((0,y-rh*0.85), 1, rh*0.92,
                           transform=ax_t.transAxes, facecolor=bg,
                           edgecolor="none", zorder=0))
            vals = [str(ri+1), s.get("formattedClock",""),
                    s.get("shooter",""), body, snat, press, rl]
            for ci, (val, x) in enumerate(zip(vals, xs)):
                ax_t.text(x, y, val, transform=ax_t.transAxes,
                          fontsize=8.5, va="top", ha="left",
                          fontfamily="monospace",
                          color=rc if ci==len(vals)-1 else "white",
                          weight="bold" if ci==len(vals)-1 else "normal",
                          zorder=1)
        ax_t.set_xlim(0,1); ax_t.set_ylim(0,1)

        legend_els = [
            Line2D([0],[0],lw=0,marker="*",markersize=14,
                   markerfacecolor="#00ee44",markeredgecolor="white",
                   markeredgewidth=1.5,label="Goal"),
            Line2D([0],[0],lw=0,marker="o",markersize=11,
                   markerfacecolor="#44aaff",markeredgecolor="white",
                   markeredgewidth=1.2,label="On Target (Saved)"),
            Line2D([0],[0],lw=0,marker="D",markersize=10,
                   markerfacecolor="#ffaa00",markeredgecolor="white",
                   markeredgewidth=1.0,label="Blocked"),
            Line2D([0],[0],lw=0,marker="X",markersize=10,
                   markerfacecolor="#ff4444",markeredgecolor="white",
                   markeredgewidth=0.8,label="Off Target"),
        ]
        fig.legend(handles=legend_els, facecolor="#2a2a2a", labelcolor="white",
                   fontsize=11, loc="upper center", ncol=4, framealpha=0.9,
                   bbox_to_anchor=(0.5,0.995), edgecolor="#444444")
        fig.suptitle(f"Shot Map — {tlabel}  |  {meta['stage']}: {meta['label']}",
                     color="white", fontsize=14, weight="bold", y=1.01)
        fig.savefig(fname, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
        plt.close()

    if not fra.empty:
        _draw(fra, "France", f"{out_dir}/05a_shot_map_france_{game_id}.png")
        print(f"  -> 05a_shot_map_france_{game_id}.png")
    if not opp_s.empty:
        _draw(opp_s, opp, f"{out_dir}/05b_shot_map_opponent_{game_id}.png")
        print(f"  -> 05b_shot_map_opponent_{game_id}.png")


