# PER-GAME 11 — TEAM SHAPE AROUND BIG MOMENTS
# Big moments detected from raw data:
#   Goals     : possEventType=SH + shotOutcome=G (not nonEvent, not pen shootout)
#   Own Goals : gameEventType=G
#   Subs      : gameEventType=SUB
# No red cards are present in these 7 games (all OFF events = temporary injury exits
# confirmed by the player returning in later events).
# ════════════════════════════════════════════════════════════
def extract_big_moments(raw, game_id, france_is_home):
    """Return list of big moment dicts sorted by clock."""
    moments = []
    is_pen = lambda clock: (game_id == "10517" and clock > 120 * 60)

    for i, r in enumerate(raw):
        ge  = r.get("gameEvents")       or {}
        pe  = r.get("possessionEvents") or {}
        clock = ge.get("startGameClock", 0) or 0
        fmt   = ge.get("startFormattedGameClock", "")
        etype = ge.get("gameEventType", "")
        team  = ge.get("teamName", "")

        # Skip nonEvents
        if pe.get("nonEvent"):
            continue

        # Goal (regular shot)
        # Note: gameEventType=G is NOT a reliable own goal signal in this data —
        # it fires as a PFF internal marker and does not correspond to real goals.
        # All real goals are captured via shotOutcomeType=G only.
        if pe.get("shotOutcomeType") == "G" and not is_pen(clock):
            scorer   = pe.get("shooterPlayerName", "") or "Unknown"
            is_fra   = (team == "France")
            short_sc = SHORT_NAME.get(scorer, scorer.split()[-1] if scorer else "?")
            team_lbl = "France" if is_fra else GAME_META[game_id]["opponent"]
            moments.append({
                "clock": clock, "fmt": fmt, "type": "goal",
                "label": f"[G] GOAL {team_lbl}\n{short_sc} {fmt}",
                "team": team_lbl, "is_france": is_fra,
                "color": "#00ee44" if is_fra else "#ff4444",
            })

        # Substitution — separate if (not elif) so a row can't block goal detection
        if etype == "SUB" and not is_pen(clock):
            off  = ge.get("playerOffName", "") or "?"
            on   = ge.get("playerOnName",  "") or "?"
            # SUB team is often None in data — infer from next OTB event
            sub_team = team
            if not sub_team:
                for j in range(i+1, min(i+5, len(raw))):
                    t2 = (raw[j].get("gameEvents") or {}).get("teamName","")
                    if t2: sub_team = t2; break
            is_fra = (sub_team == "France")
            off_s  = SHORT_NAME.get(off,  off.split()[-1]  if off  else "?")
            on_s   = SHORT_NAME.get(on,   on.split()[-1]   if on   else "?")
            team_lbl = "France" if is_fra else GAME_META[game_id]["opponent"]
            moments.append({
                "clock": clock, "fmt": fmt, "type": "sub",
                "label": f"[SUB] {team_lbl}\n↓{off_s} ↑{on_s} {fmt}",
                "team": team_lbl, "is_france": is_fra,
                "color": "#4488ff" if is_fra else "#ffaa00",
                "off": off, "on": on,
            })

    # Deduplicate subs that happen same clock (batch subs) — keep one entry per clock+type+team
    seen = set()
    deduped = []
    for m in moments:
        key = (m["clock"], m["type"], m.get("team",""))
        if key not in seen or m["type"] != "sub":
            deduped.append(m)
            seen.add(key)

    deduped.sort(key=lambda m: m["clock"])
    return deduped


def get_team_avg_positions(raw, clock_start, clock_end, france_is_home):
    """
    Average x/y position of each outfield France player across all
    tracking snapshots in [clock_start, clock_end].
    Returns dict: jersey -> {x, y, name, n}
    """
    positions = {}
    for r in raw:
        ge  = r.get("gameEvents")       or {}
        pe  = r.get("possessionEvents") or {}
        if pe.get("nonEvent"): continue
        clock  = ge.get("startGameClock", 0) or 0
        period = str(ge.get("period", ""))
        if not (clock_start <= clock <= clock_end): continue

        players = r.get("homePlayers" if france_is_home else "awayPlayers") or []
        for p in players:
            j = str(p.get("jerseyNum", ""))
            if j == "1": continue          # exclude keeper
            x = p.get("x"); y = p.get("y")
            if x is None or y is None: continue
            # Apply same coord normalisation as load_and_flatten
            if period == "2": x, y = -x, -y
            if not france_is_home: x, y = -x, -y
            if j not in positions:
                positions[j] = {"xs": [], "ys": [], "name": p.get("playerName", "")}
            positions[j]["xs"].append(x)
            positions[j]["ys"].append(y)

    result = {}
    for j, d in positions.items():
        if len(d["xs"]) >= 3:          # need at least 3 snapshots
            result[j] = {
                "x":    float(np.mean(d["xs"])),
                "y":    float(np.mean(d["ys"])),
                "name": d["name"],
                "n":    len(d["xs"]),
            }
    return result


