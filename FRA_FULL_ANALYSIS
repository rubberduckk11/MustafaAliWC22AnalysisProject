# PER-GAME 4 — CHANCE CREATION
# ════════════════════════════════════════════════════════════
def plot_chance_creation(df, game_id, out_dir):
    meta = GAME_META[game_id]; opp = meta["opponent"]
    df = df[~df["is_pen_shootout"]]

    fra_pos = df[df["opportunityType"].isin(["C","H","D"]) & df["is_france"]
                 & df["ball_x"].notna() & (df["ball_x"]>=0)].copy()
    opp_pos = df[df["opportunityType"].isin(["C","H","D"]) & ~df["is_france"]
                 & df["ball_x"].notna() & (df["ball_x"]<=0)].copy()
    goals = df[df["shotOutcome"]=="G"].copy()

    fig, ax = plt.subplots(figsize=(18,11), facecolor="#1a1a1a")
    draw_pitch(ax); patches = []

    LS = {"PA":"-","CR":"--","CH":":","CL":"-."}
    SZ = {"C":300,"H":150,"D":80}
    MK = {"C":"*","H":"o","D":"o"}

    def draw_arrows(sub, col, aa=0.6, ad=0.9):
        for _, row in sub.iterrows():
            x1,y1 = row["ball_x"], row["ball_y"]
            x2 = row["end_x"] if pd.notna(row.get("end_x")) else x1
            y2 = row["end_y"] if pd.notna(row.get("end_y")) else y1
            ot = row["opportunityType"]
            ax.annotate("", xy=(x2,y2), xytext=(x1,y1),
                        arrowprops=dict(arrowstyle="-|>", color=col, lw=1.3,
                                        linestyle=LS.get(row.get("possEventType","PA"),"-"),
                                        mutation_scale=10, alpha=aa), zorder=4)
            ax.scatter(x1,y1, c=col, s=20, alpha=0.45, zorder=5, edgecolors="none")
            ax.scatter(x2,y2, c=col, s=SZ.get(ot,80), marker=MK.get(ot,"o"),
                       alpha=ad, zorder=6,
                       edgecolors="white" if ot=="C" else "none",
                       linewidths=1.2 if ot=="C" else 0)

    for ot, col, lbl in [("C","#ff3333","FRA Chance"),("H","#ff8800","FRA Half Chance"),("D","#ffff00","FRA Dangerous")]:
        sub = fra_pos[fra_pos["opportunityType"]==ot]
        if sub.empty: continue
        draw_arrows(sub, col)
        patches.append(mpatches.Patch(color=col, label=f"{lbl} (n={len(sub)})"))

    for ot, col, lbl in [("C","#cc00cc","OPP Chance"),("H","#9933ff","OPP Half Chance"),("D","#4488ff","OPP Dangerous")]:
        sub = opp_pos[opp_pos["opportunityType"]==ot]
        if sub.empty: continue
        draw_arrows(sub, col)
        patches.append(mpatches.Patch(color=col, label=f"{lbl} (n={len(sub)})"))

    for _, g in goals.iterrows():
        gx, gy = g["ball_x"], g["ball_y"]
        col = "#00ff00" if g["is_france"] else "#ff4444"
        ax.scatter(gx, gy, c=col, s=500, marker="*", zorder=8,
                   edgecolors="white", linewidths=1.5)
        name = SHORT_NAME.get(g["shooter"], (g["shooter"] or "").split()[-1])
        ax.text(gx, gy+3.5, f"GOAL: {name}", ha="center", fontsize=8,
                color="white", weight="bold", zorder=9)

    patches += [mpatches.Patch(color="#00ff00", label="France Goal"),
                mpatches.Patch(color="#ff4444", label=f"{opp} Goal")]
    leg = ax.legend(handles=patches, facecolor="#333", labelcolor="white",
                    fontsize=8, loc="upper left", framealpha=0.85, ncol=2,
                    title="Opportunity Level", title_fontsize=8)
    leg.get_title().set_color("white")

    title = (f"Chance Creation & Goal Map — {meta['stage']}: {meta['label']}\n"
             f"France attacks → | Warm=France benefit | Cool={opp} benefit")
    if game_id == "10517":
        title += "\n(Penalty shootout excluded)"
    ax.set_title(title, color="white", fontsize=11, weight="bold", pad=10)

    fig.savefig(f"{out_dir}/04_chance_creation_{game_id}.png",
                dpi=150, bbox_inches="tight", facecolor="#1a1a1a"); plt.close()
    print(f"  -> 04_chance_creation_{game_id}.png")


