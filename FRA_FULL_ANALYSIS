# ════════════════════════════════════════════════════════════
# LOAD & FLATTEN
# Two filters applied on every row before it enters the DataFrame:
#   1. nonEvent=True  — data provider flagged row as not a real event
#      (removes e.g. Griezmann's disallowed goal vs TUN, Ghandri phantom goal)
#   2. is_pen_shootout — Argentina clock > 120 min = penalty shootout
#      These rows are kept in the df but tagged so plots can exclude them.
# ════════════════════════════════════════════════════════════
def load_and_flatten(path, game_id):
    with open(path, encoding="utf-8") as f:
        raw = json.load(f)
    if not isinstance(raw, list) or not raw or "gameEvents" not in (raw[0] or {}):
        raise ValueError(f"Bad file: {path}")

    rows = []
    for i, r in enumerate(raw):
        ge       = r.get("gameEvents")       or {}
        it       = r.get("initialTouch")     or {}
        pe       = r.get("possessionEvents") or {}
        fo_raw   = r.get("fouls")            or {}
        fo       = fo_raw if isinstance(fo_raw, dict) else (fo_raw[0] if fo_raw else {})
        gr       = r.get("grades")           or {}
        ball_raw = r.get("ball")             or []
        ball     = ball_raw[0] if isinstance(ball_raw, list) and ball_raw else {}

        # ── Drop rows the data provider marked as non-events ─────────────────
        if pe.get("nonEvent"):
            continue

        home_players = {str(p["jerseyNum"]): p for p in (r.get("homePlayers") or [])}
        away_players = {str(p["jerseyNum"]): p for p in (r.get("awayPlayers") or [])}

        end_x = end_y = None
        rec_id  = pe.get("receiverPlayerId")
        targ_id = pe.get("targetPlayerId")
        pool    = (r.get("homePlayers") or []) + (r.get("awayPlayers") or [])
        if rec_id is not None:
            for p in pool:
                if p.get("playerId") == rec_id:
                    end_x, end_y = p.get("x"), p.get("y"); break
        if end_x is None and targ_id is not None:
            for p in pool:
                if p.get("playerId") == targ_id:
                    end_x, end_y = p.get("x"), p.get("y"); break
        if end_x is None and i + 1 < len(raw):
            nb = raw[i + 1].get("ball") or []
            if nb:
                end_x, end_y = nb[0].get("x"), nb[0].get("y")

        clock_sec     = ge.get("startGameClock") or 0
        is_pen        = (game_id == "10517" and clock_sec > 120 * 60)

        rows.append({
            "game_id":              game_id,
            "sequence":             r.get("sequence"),
            "period":               ge.get("period"),
            "homeTeam":             ge.get("homeTeam"),
            "teamName":             ge.get("teamName"),
            "playerName":           ge.get("playerName"),
            "setpieceType":         ge.get("setpieceType"),
            "startGameClock":       clock_sec,
            "formattedClock":       ge.get("startFormattedGameClock"),
            "initialPressureType":  it.get("initialPressureType"),
            "possEventType":        pe.get("possessionEventType"),
            "pressureType":         pe.get("pressureType"),
            "pressurePlayer":       pe.get("pressurePlayerName"),
            "opportunityType":      pe.get("opportunityType"),
            "linesBroken":          pe.get("linesBrokenType"),
            "betterOption":         pe.get("betterOptionType"),
            "createsSpace":         pe.get("createsSpace"),
            "passer":               pe.get("passerPlayerName"),
            "passType":             pe.get("passType"),
            "passOutcome":          pe.get("passOutcomeType"),
            "target":               pe.get("targetPlayerName"),
            "receiver":             pe.get("receiverPlayerName"),
            "accuracyType":         pe.get("accuracyType"),
            "crossType":            pe.get("crossType"),
            "crossOutcome":         pe.get("crossOutcomeType"),
            "shooter":              pe.get("shooterPlayerName"),
            "shotType":             pe.get("shotType"),
            "shotNature":           pe.get("shotNatureType"),
            "shotOutcome":          pe.get("shotOutcomeType"),
            "challengeType":        pe.get("challengeType"),
            "challenger":           pe.get("challengerPlayerName"),
            "challengeWinner":      pe.get("challengeWinnerPlayerName"),
            "carrier":              pe.get("carrierPlayerName"),
            "dribbler":             pe.get("dribblerPlayerName"),
            "carryType":            pe.get("carryType"),
            "carryIntent":          pe.get("carryIntent"),
            "carrySuccessful":      pe.get("carrySuccessful"),
            "ballCarrier":          pe.get("ballCarrierPlayerName"),
            "shotInitialHeight":    pe.get("shotInitialHeightType"),
            "bodyType":             pe.get("bodyType"),
            "passerGrade":          gr.get("passerGrade"),
            "receiverGrade":        gr.get("receiverGrade"),
            "targetGrade":          gr.get("targetGrade"),
            "shooterGrade":         gr.get("shooterGrade"),
            "dribbleGrade":         gr.get("dribblerGrade"),
            "challengerGrade":      gr.get("challengerGrade"),
            "carrierGrade":         gr.get("carrierGrade"),
            "ballCarrierGrade":     gr.get("ballCarrierGrade"),
            "foulType":             fo.get("foulType"),
            "victim":               fo.get("victimPlayerName"),
            "ball_x":               ball.get("x"),
            "ball_y":               ball.get("y"),
            "end_x":                end_x,
            "end_y":                end_y,
            "is_pen_shootout":      is_pen,
            "_home_players":        home_players,
            "_away_players":        away_players,
        })

    df = pd.DataFrame(rows)

    # Determine France home/away
    france_is_home = True
    fr = df[df["teamName"] == "France"]["homeTeam"]
    if len(fr):
        france_is_home = bool(fr.mode().iloc[0])

    # Flip period 2 so France always attacks right (+x)
    mask2 = df["period"].astype(str) == "2"
    df.loc[mask2, ["ball_x","ball_y","end_x","end_y"]] *= -1

    # If France is the away side, flip all coords
    if not france_is_home:
        df[["ball_x","ball_y","end_x","end_y"]] *= -1

    df["is_france"] = df["teamName"] == "France"
    return df, france_is_home


