# PER-GAME 10 — SEQUENCE ANALYSIS
# ════════════════════════════════════════════════════════════
def plot_sequence_analysis(df, game_id, out_dir):
    meta = GAME_META[game_id]; opp = meta["opponent"]
    df = df[~df["is_pen_shootout"]]

    raw_seqs = defaultdict(lambda: {
        'team':None,'n_events':0,'start_clock':None,
        'has_shot':False,'has_opp':False,'shot_outcome':None,'setpiece':False,
    })
    for _, row in df.iterrows():
        seq = row.get("sequence")
        if seq is None or (isinstance(seq, float) and pd.isna(seq)): continue
        try: seq = int(seq)
        except: continue
        s = raw_seqs[seq]
        s['team'] = row.get("teamName")
        clock = row.get("startGameClock") or 0
        if s['start_clock'] is None: s['start_clock'] = clock
        s['n_events'] += 1
        if row.get("possEventType")=="SH":
            s['has_shot'] = True; s['shot_outcome'] = row.get("shotOutcome")
        if row.get("opportunityType") in ('C','H','D'): s['has_opp'] = True
        sp = row.get("setpieceType")
        if sp and sp not in ('O','K'): s['setpiece'] = True

    fra_s = [s for s in raw_seqs.values() if s['team']=='France' and s['start_clock'] is not None]
    opp_s = [s for s in raw_seqs.values() if s['team'] and s['team']!='France' and s['start_clock'] is not None]
    if not fra_s or not opp_s: print("  No sequence data"); return

    windows   = [(0,15,'0-15'),(15,30,'15-30'),(30,45,'30-45'),
                 (45,60,'45-60'),(60,75,'60-75'),(75,200,'75-90+')]
    win_labels = [w[2] for w in windows]

    def wst(seqs, wins):
        out = []
        for ws, we, _ in wins:
            w = [s for s in seqs if ws*60 <= (s['start_clock'] or 0) < we*60]
            out.append({'n':len(w),
                        'shots': sum(1 for s in w if s['has_shot']),
                        'avg_len': sum(s['n_events'] for s in w)/max(len(w),1)})
        return out

    fs = wst(fra_s, windows); ds = wst(opp_s, windows)
    fig = plt.figure(figsize=(22,14), facecolor="#1a1a1a")
    gs  = fig.add_gridspec(2,3, hspace=0.35, wspace=0.3,
                           left=0.07, right=0.97, top=0.91, bottom=0.06)
    x = range(len(win_labels))

    def stax(ax):
        style_dark_ax(ax)
        ax.set_xticks(x); ax.set_xticklabels(win_labels, color="white", fontsize=8)

    ax1 = fig.add_subplot(gs[0,0]); stax(ax1)
    ax1.plot(x,[s['n'] for s in fs],'o-',color="#4488ff",lw=2,ms=7,label="France")
    ax1.plot(x,[s['n'] for s in ds],'s-',color="#ff4444",lw=2,ms=7,label=opp)
    ax1.set_ylabel("Sequences",color="white",fontsize=9)
    ax1.set_title("Sequences per 15-min Window",color="white",fontsize=10,weight="bold")
    ax1.legend(facecolor="#333",labelcolor="white",fontsize=8)

    ax2 = fig.add_subplot(gs[0,1]); stax(ax2)
    ax2.bar([xi-0.2 for xi in x],[s['shots'] for s in fs],width=0.38,color="#4488ff",alpha=0.85,label="France")
    ax2.bar([xi+0.2 for xi in x],[s['shots'] for s in ds],width=0.38,color="#ff4444",alpha=0.85,label=opp)
    ax2.set_ylabel("Seqs with Shot",color="white",fontsize=9)
    ax2.set_title("Shot-Ending Sequences",color="white",fontsize=10,weight="bold")
    ax2.legend(facecolor="#333",labelcolor="white",fontsize=8)

    ax3 = fig.add_subplot(gs[0,2]); stax(ax3)
    ax3.plot(x,[s['avg_len'] for s in fs],'o-',color="#4488ff",lw=2,ms=7,label="France")
    ax3.plot(x,[s['avg_len'] for s in ds],'s-',color="#ff4444",lw=2,ms=7,label=opp)
    ax3.set_ylabel("Avg Events",color="white",fontsize=9)
    ax3.set_title("Avg Sequence Length",color="white",fontsize=10,weight="bold")
    ax3.legend(facecolor="#333",labelcolor="white",fontsize=8)

    ax4 = fig.add_subplot(gs[1,0]); style_dark_ax(ax4)
    fl = [s['n_events'] for s in fra_s]; dl = [s['n_events'] for s in opp_s]
    bins = range(1, max(max(fl),max(dl))+2, 2)
    ax4.hist(fl,bins=bins,color="#4488ff",alpha=0.65,density=True,
             label=f"France (avg {np.mean(fl):.1f})")
    ax4.hist(dl,bins=bins,color="#ff4444",alpha=0.65,density=True,
             label=f"{opp} (avg {np.mean(dl):.1f})")
    ax4.set_xlabel("Events per Sequence",color="white",fontsize=9)
    ax4.set_ylabel("Density",color="white",fontsize=9)
    ax4.set_title("Sequence Length Distribution",color="white",fontsize=10,weight="bold")
    ax4.legend(facecolor="#333",labelcolor="white",fontsize=8)

    ax5 = fig.add_subplot(gs[1,1]); style_dark_ax(ax5)
    def oc(seqs):
        g   = sum(1 for s in seqs if s['shot_outcome']=='G')
        sh  = sum(1 for s in seqs if s['has_shot'] and s['shot_outcome']!='G')
        opc = sum(1 for s in seqs if s['has_opp'] and not s['has_shot'])
        oth = len(seqs)-g-sh-opc
        return [g,sh,opc,oth]
    foc = oc(fra_s); doc = oc(opp_s)
    oc_labels  = ['Goal','Shot\n(no goal)','Opp\n(no shot)','No threat']
    oc_colours = ['#00ee44','#44aaff','#ffff00','#555555']
    for i,(col,lbl) in enumerate(zip(oc_colours,oc_labels)):
        fp2 = 100*foc[i]/len(fra_s); dp2 = 100*doc[i]/len(opp_s)
        ax5.bar(i-0.2,fp2,width=0.38,color=col,alpha=0.85,edgecolor="#333")
        ax5.bar(i+0.2,dp2,width=0.38,color=col,alpha=0.5,edgecolor="#333",hatch="//")
        ax5.text(i-0.2,fp2+0.5,f"{fp2:.0f}%",ha='center',fontsize=7.5,color='white')
        ax5.text(i+0.2,dp2+0.5,f"{dp2:.0f}%",ha='center',fontsize=7.5,color='white')
    ax5.set_xticks([0,1,2,3]); ax5.set_xticklabels(oc_labels,color="white",fontsize=7.5)
    ax5.set_ylabel("% of sequences",color="white",fontsize=9)
    ax5.set_title("Sequence Outcome Breakdown",color="white",fontsize=10,weight="bold")
    from matplotlib.patches import Patch
    ax5.legend(handles=[Patch(facecolor='white',alpha=0.85,label='France'),
                         Patch(facecolor='white',alpha=0.5,hatch='//',label=opp)],
               facecolor="#333",labelcolor="white",fontsize=8)

    ax6 = fig.add_subplot(gs[1,2]); ax6.set_facecolor("#1a1a1a"); ax6.axis("off")
    def pct(n,t): return f"{100*n//max(t,1)}%"
    sum_rows = [
        ("Metric","France",opp),
        ("Total sequences",str(len(fra_s)),str(len(opp_s))),
        ("Avg length",f"{np.mean(fl):.1f}",f"{np.mean(dl):.1f}"),
        ("Max length",str(max(fl)),str(max(dl))),
        ("With shot",f"{sum(s['has_shot'] for s in fra_s)} ({pct(sum(s['has_shot'] for s in fra_s),len(fra_s))})",
                     f"{sum(s['has_shot'] for s in opp_s)} ({pct(sum(s['has_shot'] for s in opp_s),len(opp_s))})"),
        ("With opp C/H/D",f"{sum(s['has_opp'] for s in fra_s)} ({pct(sum(s['has_opp'] for s in fra_s),len(fra_s))})",
                          f"{sum(s['has_opp'] for s in opp_s)} ({pct(sum(s['has_opp'] for s in opp_s),len(opp_s))})"),
        ("Goals",str(sum(1 for s in fra_s if s['shot_outcome']=='G')),
                 str(sum(1 for s in opp_s if s['shot_outcome']=='G'))),
        ("Set pieces",str(sum(s['setpiece'] for s in fra_s)),
                      str(sum(s['setpiece'] for s in opp_s))),
    ]
    rh2 = 1.0/len(sum_rows)
    for ri,(m,fv,dv) in enumerate(sum_rows):
        y = 1.0-ri*rh2; ih = ri==0
        bg = "#111111" if ih else ("#222222" if ri%2==0 else "#1a1a1a")
        ax6.add_patch(plt.Rectangle((0,y-rh2),1,rh2,transform=ax6.transAxes,
                      facecolor=bg,edgecolor="#444",zorder=0))
        ax6.text(0.02,y-rh2*0.3,m,transform=ax6.transAxes,fontsize=8.5,
                 color="white",weight="bold" if ih else "normal",
                 va="center",fontfamily="monospace")
        ax6.text(0.52,y-rh2*0.3,fv,transform=ax6.transAxes,fontsize=8.5,
                 color="#4488ff" if not ih else "white",
                 weight="bold" if ih else "normal",
                 va="center",fontfamily="monospace")
        ax6.text(0.78,y-rh2*0.3,dv,transform=ax6.transAxes,fontsize=8.5,
                 color="#ff4444" if not ih else "white",
                 weight="bold" if ih else "normal",
                 va="center",fontfamily="monospace")
    ax6.set_xlim(0,1); ax6.set_ylim(0,1)
    ax6.set_title("Summary Stats",color="white",fontsize=10,weight="bold",pad=6)

    fig.suptitle(f"Sequence & Build-Up Analysis — {meta['stage']}: {meta['label']}",
                 color="white",fontsize=13,weight="bold",y=0.975)
    fig.savefig(f"{out_dir}/10_sequence_analysis_{game_id}.png",
                dpi=150,bbox_inches="tight",facecolor="#1a1a1a"); plt.close()
    print(f"  -> 10_sequence_analysis_{game_id}.png")


# ════════════════════════════════════════════════════════════
# COMPARATIVE STATS BUILDER
# All stats exclude nonEvent rows (handled at load time) and
# Argentina penalty shootout rows (is_pen_shootout==True).
# ════════════════════════════════════════════════════════════
def build_comparative_stats(all_dfs, all_home):
    GMAP = {"passerGrade":"passer","receiverGrade":"receiver",
            "shooterGrade":"shooter","dribbleGrade":"dribbler",
            "challengerGrade":"challenger","carrierGrade":"carrier"}
    MBAPPE_J = "10"
    stats = []

    for game_id, df in all_dfs.items():
        meta = GAME_META[game_id]
        fih  = all_home[game_id]
        # drop pen shootout for all comparative stats
        df = df[~df["is_pen_shootout"]]

        fra_sh  = df[ df["is_france"] & (df["possEventType"]=="SH")]
        opp_sh  = df[~df["is_france"] & (df["possEventType"]=="SH")]
        fra_g   = len(fra_sh[fra_sh["shotOutcome"]=="G"])
        opp_g   = len(opp_sh[opp_sh["shotOutcome"]=="G"])

        fra_pa  = df[df["is_france"] & (df["possEventType"]=="PA") & df["passer"].notna()]
        fra_cp  = len(fra_pa[fra_pa["passOutcome"]=="C"])

        fra_pr  = df[ df["is_france"] & df["pressureType"].isin(["P","A"])]
        opp_pr  = df[~df["is_france"] & df["pressureType"].isin(["P","A"])]
        fra_lb  = df[ df["is_france"] & df["linesBroken"].notna()]
        opp_lb  = df[~df["is_france"] & df["linesBroken"].notna()]
        fra_ch  = df[ df["is_france"] & df["opportunityType"].isin(["C","H","D"])]
        opp_ch  = df[~df["is_france"] & df["opportunityType"].isin(["C","H","D"])]

        mb_s   = df[df["shooter"]=="Kylian Mbappé"]
        mb_p   = df[df["passer"]=="Kylian Mbappé"]
        mb_g   = len(mb_s[mb_s["shotOutcome"]=="G"])
        mb_pc  = len(mb_p[mb_p["passOutcome"]=="C"])

        gr = [float(row.get(gc)) for _, row in df[df["is_france"]].iterrows()
              for gc, pc in GMAP.items()
              if not pd.isna(row.get(gc)) and row.get(pc) in FRANCE_PLAYERS]
        avg_gr = float(np.mean(gr)) if gr else 0.0

        dists = []
        for _, row in df[df["is_france"]].iterrows():
            hp = row["_home_players"]; ap = row["_away_players"]
            mb = hp.get(MBAPPE_J) if fih else ap.get(MBAPPE_J)
            defenders = ap if fih else hp
            if not mb: continue
            period = str(row.get("period",""))
            mx = mb.get("x",0); my = mb.get("y",0)
            if period=="2": mx,my = -mx,-my
            if not fih: mx,my = -mx,-my
            min_d = 999
            for jnum, p in defenders.items():
                ax_ = p.get("x",0); ay_ = p.get("y",0)
                if period=="2": ax_,ay_ = -ax_,-ay_
                if not fih: ax_,ay_ = -ax_,-ay_
                d = np.sqrt((mx-ax_)**2+(my-ay_)**2)
                if d < min_d: min_d = d
            dists.append(min_d)

        stats.append({
            "game_id":          game_id,
            "label":            meta["label"],
            "label_short":      meta["label_short"],
            "opponent":         meta["opponent"],
            "stage":            meta["stage"],
            "result":           meta["result"],
            "fra_goals":        fra_g,
            "opp_goals":        opp_g,
            "fra_shots":        len(fra_sh),
            "opp_shots":        len(opp_sh),
            "fra_shot_conv":    100*fra_g/max(len(fra_sh),1),
            "opp_shot_conv":    100*opp_g/max(len(opp_sh),1),
            "fra_pass_comp":    100*fra_cp/max(len(fra_pa),1),
            "fra_pass_total":   len(fra_pa),
            "fra_press":        len(fra_pr),
            "opp_press":        len(opp_pr),
            "fra_lb":           len(fra_lb),
            "opp_lb":           len(opp_lb),
            "fra_chances":      len(fra_ch),
            "opp_chances":      len(opp_ch),
            "fra_C": len(fra_ch[fra_ch["opportunityType"]=="C"]),
            "fra_H": len(fra_ch[fra_ch["opportunityType"]=="H"]),
            "fra_D": len(fra_ch[fra_ch["opportunityType"]=="D"]),
            "opp_C": len(opp_ch[opp_ch["opportunityType"]=="C"]),
            "opp_H": len(opp_ch[opp_ch["opportunityType"]=="H"]),
            "opp_D": len(opp_ch[opp_ch["opportunityType"]=="D"]),
            "mbappe_shots":     len(mb_s),
            "mbappe_goals":     mb_g,
            "mbappe_passes":    len(mb_p),
            "mbappe_pass_comp": 100*mb_pc/max(len(mb_p),1),
            "avg_grade":        avg_gr,
            "mbappe_avg_dist":  float(np.mean(dists)) if dists else 0.0,
            "mbappe_tight_pct": 100*sum(1 for d in dists if d<=5)/max(len(dists),1),
        })
    return pd.DataFrame(stats)


