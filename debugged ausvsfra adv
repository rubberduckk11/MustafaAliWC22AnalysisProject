def plot_lines_broken(df):
    print("[3/6] Lines broken...")

    france_lb = df[
        (df["homeTeam"] == True) &
        df["linesBroken"].notna() &
        df["ball_x"].notna()
    ].copy()

    # Copy first, then flip so Australia attacks right on their map
    aus_lb = df[
        (df["homeTeam"] == False) &
        df["linesBroken"].notna() &
        df["ball_x"].notna()
    ].copy()
    aus_lb["ball_x"] = -aus_lb["ball_x"]
    aus_lb["ball_y"] = -aus_lb["ball_y"]

    fig, axes = plt.subplots(1, 2, figsize=(18, 7), facecolor="#1a1a1a")

    for ax, data, title in [
        (axes[0], france_lb, "France Line-Breaking Events"),
        (axes[1], aus_lb,    "Australia Line-Breaking Events"),
    ]:
        draw_pitch(ax)
        patches = []
        for ltype, (col, label) in LINE_COLORS.items():
