# 7.  PLAYER GRADES  (France only)

 
def plot_player_grades(df):
    print("[5/6] Player grades...")
 
    grade_player_map = {
        "passerGrade":      "passer",
        "receiverGrade":    "receiver",
        "targetGrade":      "target",
        "shooterGrade":     "shooter",
        "dribbleGrade":     "dribbler",
        "challengerGrade":  "challenger",
        "carrierGrade":     "carrier",
        "ballCarrierGrade": "ballCarrier",
    }
 
    grade_rows = []
    for _, row in df.iterrows():
        for grade_col, player_col in grade_player_map.items():
            grade  = row.get(grade_col)
            player = row.get(player_col)
            if pd.isna(grade) or not player:
                continue
            if player not in FRANCE_PLAYERS:
                continue
            grade_rows.append({"player": player, "grade": float(grade)})
 
    if not grade_rows:
        print("  No France grade data found.")
        return
 
    gdf     = pd.DataFrame(grade_rows)
    summary = (gdf.groupby("player")
                  .agg(avg_grade=("grade", "mean"), n=("grade", "count"))
                  .reset_index()
                  .sort_values("avg_grade", ascending=True))
 
    n_players  = len(summary)
    fig_height = max(7, n_players * 0.6 + 2)
    fig, ax    = plt.subplots(figsize=(12, fig_height), facecolor="#1a1a1a")
    ax.set_facecolor("#1a1a1a")
 
    colors = ["#ff4444" if g < -0.005 else
              "#44ff44" if g >  0.005 else "#888888"
              for g in summary["avg_grade"]]
 
    bars = ax.barh(range(n_players), summary["avg_grade"],
                   color=colors, alpha=0.85,
                   edgecolor="#555", linewidth=0.5, height=0.65)
 
    ax.set_yticks(range(n_players))
    ax.set_yticklabels(summary["player"], fontsize=10, color="white")
    ax.set_ylim(-0.7, n_players - 0.3)
 
    xmax = summary["avg_grade"].abs().max()
    ax.set_xlim(-xmax * 1.6, xmax * 1.6)
 
    ax.axvline(0, color="white", lw=1.2, alpha=0.7)
 
    for bar, (_, row) in zip(bars, summary.iterrows()):
        x      = bar.get_width()
        offset = xmax * 0.04 if x >= 0 else -xmax * 0.04
        ha     = "left" if x >= 0 else "right"
        ax.text(x + offset,
                bar.get_y() + bar.get_height() / 2,
                f"{row['avg_grade']:+.3f}  (n={int(row['n'])})",
                va="center", ha=ha, color="white", fontsize=9)
 
    ax.set_xlabel("Average PFF Grade  (−2 to +2,  0 = expected)",
                  color="white", fontsize=10)
    ax.set_title("France Player Average Grades — FRA vs AUS (WC MD1 2022)",
                 color="white", fontsize=12, weight="bold", pad=12)
    ax.tick_params(colors="white")
    plt.setp(ax.get_xticklabels(), color="white")
    for spine in ax.spines.values():
        spine.set_edgecolor("#555")
 
    patches = [
        mpatches.Patch(color="#44ff44", label="Above expected"),
        mpatches.Patch(color="#888888", label="Expected (~0)"),
        mpatches.Patch(color="#ff4444", label="Below expected"),
    ]
    ax.legend(handles=patches, facecolor="#333", labelcolor="white",
              fontsize=9, loc="lower right")
 
    plt.tight_layout()
    out = f"{OUT_DIR}/player_grades_france.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
 
