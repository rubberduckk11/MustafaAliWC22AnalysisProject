# 1.  LOAD & FLATTEN

 
def load_and_flatten(path):
    with open(path, encoding="utf-8") as f:
        raw = json.load(f)
 
    rows = []
    for r in raw:
        ge      = r.get("gameEvents")       or {}
        it      = r.get("initialTouch")     or {}
        pe      = r.get("possessionEvents") or {}
        fo_raw  = r.get("fouls")            or {}
        fo      = fo_raw if isinstance(fo_raw, dict) else (fo_raw[0] if fo_raw else {})
        gr      = r.get("grades")           or {}
        ball_raw = r.get("ball") or []
        ball    = ball_raw[0] if isinstance(ball_raw, list) and ball_raw else {}
 
        home_players = {str(p["jerseyNum"]): p for p in (r.get("homePlayers") or [])}
        away_players = {str(p["jerseyNum"]): p for p in (r.get("awayPlayers") or [])}
 
        rows.append({
            # timing
            "eventTime":       r.get("eventTime"),
            "startTime":       r.get("startTime"),
            "period":          ge.get("period"),
            # game event
            "homeTeam":        ge.get("homeTeam"),
            "teamName":        ge.get("teamName"),
            "playerName":      ge.get("playerName"),
            "setpieceType":    ge.get("setpieceType"),
            "startGameClock":  ge.get("startGameClock"),
            "formattedClock":  ge.get("startFormattedGameClock"),
            # initial touch
            "initialPressureType": it.get("initialPressureType"),
            # possession event
            "possEventType":   pe.get("possessionEventType"),
            "pressureType":    pe.get("pressureType"),
            "pressurePlayer":  pe.get("pressurePlayerName"),
            "opportunityType": pe.get("opportunityType"),
            "linesBroken":     pe.get("linesBrokenType"),
            "betterOption":    pe.get("betterOptionType"),
            "createsSpace":    pe.get("createsSpace"),
            # pass / cross
            "passer":          pe.get("passerPlayerName"),
            "passType":        pe.get("passType"),
            "passOutcome":     pe.get("passOutcomeType"),
            "target":          pe.get("targetPlayerName"),
            "receiver":        pe.get("receiverPlayerName"),
            "accuracyType":    pe.get("accuracyType"),
            "crossType":       pe.get("crossType"),
            "crossOutcome":    pe.get("crossOutcomeType"),
            # shot
            "shooter":         pe.get("shooterPlayerName"),
            "shotType":        pe.get("shotType"),
            "shotNature":      pe.get("shotNatureType"),
            "shotOutcome":     pe.get("shotOutcomeType"),
            # challenge
            "challengeType":   pe.get("challengeType"),
            "challenger":      pe.get("challengerPlayerName"),
            "carrier":         pe.get("carrierPlayerName"),
            "dribbler":        pe.get("dribblerPlayerName"),
            # carry
            "carryType":       pe.get("carryType"),
            "carryIntent":     pe.get("carryIntent"),
            "carrySuccessful": pe.get("carrySuccessful"),
            "ballCarrier":     pe.get("ballCarrierPlayerName"),
            # grades
            "passerGrade":     gr.get("passerGrade"),
            "receiverGrade":   gr.get("receiverGrade"),
            "targetGrade":     gr.get("targetGrade"),
            "shooterGrade":    gr.get("shooterGrade"),
            "dribbleGrade":    gr.get("dribblerGrade"),
            "challengerGrade": gr.get("challengerGrade"),
            "carrierGrade":    gr.get("carrierGrade"),
            "ballCarrierGrade":gr.get("ballCarrierGrade"),
            # foul
            "foulType":        fo.get("foulType"),
            "offenseType":     fo.get("onFieldOffenseType"),
            "victim":          fo.get("victimPlayerName"),
            # ball position at event moment
            "ball_x":          ball.get("x"),
            "ball_y":          ball.get("y"),
            # player position snapshots (dicts keyed by jerseyNum string)
            "_home_players":   home_players,
            "_away_players":   away_players,
        })
 
    df = pd.DataFrame(rows)
 
    # Normalise: flip period 2 so France always attacks right (+x)
    mask = df["period"] == 2
    df.loc[mask, "ball_x"] *= -1
    df.loc[mask, "ball_y"] *= -1
 
    print(f"Loaded {len(df)} events")
    return df
 
 

# 2.  PITCH DRAWING HELPER

 
def draw_pitch(ax, length=105, width=68, line_color="white",
               bg="#2d5c2d", lw=1.5):
    ax.set_facecolor(bg)
    ax.set_xlim(-length/2 - 3, length/2 + 3)
    ax.set_ylim(-width/2 - 3, width/2 + 3)
    ax.set_aspect("equal")
    ax.axis("off")
    kw = dict(edgecolor=line_color, fill=False, linewidth=lw)
    ax.add_patch(Rectangle((-length/2, -width/2), length, width, **kw))
    ax.plot([0, 0], [-width/2, width/2], color=line_color, lw=lw)
    ax.add_patch(plt.Circle((0, 0), 9.15, **kw))
    ax.plot(0, 0, "o", color=line_color, ms=2)
    for side in [-1, 1]:
        xp = side * length / 2
        ax.add_patch(Rectangle((xp - side*16.5, -20.15), side*16.5, 40.3, **kw))
        ax.add_patch(Rectangle((xp - side*5.5,  -9.15),  side*5.5,  18.3, **kw))
        ax.plot(xp - side*11, 0, "o", color=line_color, ms=2)
        t1, t2 = (127, 233) if side == 1 else (307, 413)
        ax.add_patch(Arc((xp - side*11, 0), 18.3, 18.3,
                         theta1=t1, theta2=t2, color=line_color, lw=lw))
        ax.plot([xp, xp], [-3.66, 3.66], color=line_color, lw=3)
    ax.annotate("", xy=(length/2 - 2, -width/2 + 2),
                xytext=(length/2 - 10, -width/2 + 2),
                arrowprops=dict(arrowstyle="->", color=line_color, lw=1, alpha=0.5))
    ax.text(length/2 - 6, -width/2 + 4, "France attack →",
            color=line_color, fontsize=7, alpha=0.5, ha="center")
 
 
def add_third_lines(ax):
    for x in [-17.5, 17.5]:
        ax.axvline(x, color="white", lw=0.8, alpha=0.35, ls="--", zorder=1)
 
 
def add_third_counts(ax, xs, width=68):
    d = sum(1 for x in xs if x < -17.5)
    m = sum(1 for x in xs if -17.5 <= x <= 17.5)
    a = sum(1 for x in xs if x > 17.5)
    total = max(d + m + a, 1)
    for x_pos, count, label in [(-35, d, "Def"), (0, m, "Mid"), (35, a, "Att")]:
        ax.text(x_pos, -width/2 - 1.5,
                f"{label}\n{count} ({100*count//total}%)",
                ha="center", va="top", color="white", fontsize=8,
                bbox=dict(facecolor="#222", edgecolor="none", alpha=0.7, pad=2))
 
 
# 3.  PASSING NETWORK

 
def plot_passing_network(df):
    print("[1/6] Passing network...")
 
    france_passes = df[
        (df["homeTeam"] == True) &
        (df["possEventType"] == "PA") &
        df["passer"].notna() &
        df["ball_x"].notna()
    ].copy()
 
    # Node position = avg ball position when player passes
    node_pos = (france_passes.groupby("passer")[["ball_x", "ball_y"]]
                .mean()
                .rename(columns={"ball_x": "x", "ball_y": "y"}))
 
    # Edge counts (completed passes)
    completed    = france_passes[france_passes["passOutcome"] == "C"]
    edge_counts  = defaultdict(int)
    all_attempts = defaultdict(int)
 
    for _, row in completed.iterrows():
        if pd.notna(row["receiver"]):
            edge_counts[(row["passer"], row["receiver"])] += 1
 
    for _, row in france_passes.iterrows():
        if pd.notna(row["target"]):
            all_attempts[(row["passer"], row["target"])] += 1
 
    fig, ax = plt.subplots(figsize=(14, 9), facecolor="#1a1a1a")
    draw_pitch(ax)
 
    max_edge = max(edge_counts.values(), default=1)
 
    # Draw edges
    for (passer, receiver), count in edge_counts.items():
        if count < 2:
            continue
        if passer not in node_pos.index or receiver not in node_pos.index:
            continue
        x1, y1 = node_pos.loc[passer, ["x", "y"]]
        x2, y2 = node_pos.loc[receiver, ["x", "y"]]
        comp = count / max(all_attempts.get((passer, receiver), 1), 1)
        lw   = 0.8 + 5.5 * (count / max_edge)
        col  = plt.cm.RdYlGn(comp)
        ax.annotate("", xy=(x2, y2), xytext=(x1, y1),
                    arrowprops=dict(arrowstyle="-|>", color=col,
                                   lw=lw, mutation_scale=14, alpha=0.85))
 
    # Draw nodes
    pass_counts = france_passes.groupby("passer").size()
    for player, (px, py) in node_pos.iterrows():
        n    = pass_counts.get(player, 1)
        size = 150 + 700 * (n / pass_counts.max())
        ax.scatter(px, py, s=size, c="#1f77b4", zorder=5,
                   edgecolors="white", linewidths=2)
        label = SHORT_NAME.get(player, player.split()[-1])
        ax.text(px, py + 3, label, ha="center", va="bottom",
                fontsize=8, color="white", weight="bold", zorder=6)
 
    sm = ScalarMappable(cmap="RdYlGn", norm=Normalize(0, 1))
    sm.set_array([])
    cb = fig.colorbar(sm, ax=ax, fraction=0.022, pad=0.02)
    cb.set_label("Pass completion rate", color="white", fontsize=9)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color="white")
    cb.ax.yaxis.set_tick_params(color="white")
 
    ax.set_title("France Passing Network — FRA vs AUS (WC MD1 2022)",
                 color="white", fontsize=13, weight="bold", pad=10)
    ax.text(0, -37,
            "Nodes = avg passing position  |  Size = pass volume  |  "
            "Arrow width = frequency  |  Colour = completion%",
            ha="center", color="#aaaaaa", fontsize=7.5)
 
    out = f"{OUT_DIR}/passing_network_france.png"
    fig.savefig(out, dpi=150, bbox_inches="tight", facecolor="#1a1a1a")
    plt.close()
    print(f"  -> {out}")
 
 

# 4.  PRESS MAP

 
def plot_press_map(df):
