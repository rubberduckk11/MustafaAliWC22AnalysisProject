    # Left: AUS pressing France (France has ball)
    aus_press = df[
        (df["homeTeam"] == True) &
        (df["pressureType"].isin(["P", "A"])) &
        df["ball_x"].notna()
    ].copy()
    aus_full = aus_press[aus_press["pressureType"] == "P"]
 
    # Right: France pressing AUS (AUS has ball)
    # Keep same orientation — AUS ball is at negative x (their half)
    fra_press = df[
        (df["homeTeam"] == False) &
        (df["pressureType"].isin(["P", "A"])) &
        df["ball_x"].notna()
    ].copy()
    fra_full = fra_press[fra_press["pressureType"] == "P"]
 
    fig, axes = plt.subplots(1, 2, figsize=(20, 8), facecolor="#1a1a1a")
 
    datasets = [
        (axes[0], aus_press, aus_full,
         "AUS Pressure on France\n(France in possession | France attacks →)",
         "Where France were pressured by Australia"),
        (axes[1], fra_press, fra_full,
         "France Pressure on AUS\n(AUS in possession | France attacks →)",
         "Where France pressed Australia  (AUS half = negative x)"),
    ]
 
    for ax, data, full_data, title, subtitle in datasets:
        draw_pitch(ax)
        add_third_lines(ax)
        xs = data["ball_x"].values
        ys = data["ball_y"].values
 
        ax.hexbin(xs, ys, gridsize=18, cmap="hot", alpha=0.70,
