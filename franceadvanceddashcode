def load_raw(gid):
    fname = FILE_MAP[gid][0]
    with open(os.path.join(DATA_DIR, fname), encoding="utf-8") as f:
        return json.load(f)

def get_goals(raw, gid):
    goals = []
    for r in raw:
        ge = r.get("gameEvents") or {}
        pe = r.get("possessionEvents") or {}
        if pe.get("nonEvent"): continue
        clock = ge.get("startGameClock", 0) or 0
        if gid == "10517" and clock > 7200: continue
        if pe.get("shotOutcomeType") == "G":
            goals.append({"clock": clock, "is_france": ge.get("teamName") == "France",
                           "scorer": pe.get("shooterPlayerName",""),
                           "fmt": ge.get("startFormattedGameClock","")})
    return sorted(goals, key=lambda x: x["clock"])

def phase_type(clock, goals):
    prev = None
    for g in goals:
        if g["clock"] < clock: prev = g
        else: break
    if prev is None: return "opening"
    return "after_fra" if prev["is_france"] else "after_opp"

PHASE_LABELS = {"opening": "Game start", "after_fra": "After France goal",
