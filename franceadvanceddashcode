  new Chart(document.getElementById(canvasId),{{
    type:'bar',
    data:{{
      labels:data.map(p=>p.name),
      datasets:[
        {{label:'Made',     data:data.map(p=>p.made),     backgroundColor:'rgba(52,152,219,0.75)'}},
        {{label:'Received', data:data.map(p=>p.received), backgroundColor:'rgba(155,89,182,0.6)'}},
      ]
    }},
    options:{{...TC,indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{{...TC.plugins,legend:{{display:true,labels:{{color:'#999',font:{{size:9}}}}}}}},
      scales:{{
        x:{{...TC.scales.x,stacked:true,ticks:{{color:'#666',font:{{size:9}}}}}},
        y:{{...TC.scales.y,stacked:true,ticks:{{color:'#ccc',font:{{size:10}}}}}}
      }}
    }}
  }});
}}
mkNetChart('chartNetOpen','opening');
mkNetChart('chartNetFra','after_fra');
mkNetChart('chartNetOpp','after_opp');

