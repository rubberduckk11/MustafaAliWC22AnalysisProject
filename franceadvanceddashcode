  <!-- ═══════════ TAB 4 — KEY FINDINGS ═══════════ -->
  <div id="tab-findings" class="tab-content">

    <div class="section">
      <div class="stitle">analysis 1 — Mbappé involvement</div>
      <div class="g2">
        <div class="insight fix">
          <h4>France are a completely different attacking team with Mbappé involved</h4>
          <p>Sequences involving Mbappé produce <span id="find-shots-ratio">—</span>× more shots per sequence
          and <span id="find-goals-ratio">—</span>× more goals per sequence than those without him.
          Lines broken per sequence is also dramatically higher with his involvement.
          This is the single biggest tactical dependency in the dataset.</p>
        </div>
        <div class="insight">
          <h4>Pass delivery to Mbappé degrades when France chase goals</h4>
          <p>When France are behind, passes aimed at Mbappé succeed at 71%, which is slightly better than after France
          score (67%), but his own pass completion drops to 76% (vs 88–90% in other phases).
          Under pressure he is receiving less cleanly and passing less accurately.
          This is the data signature of isolation rather than connection.</p>
        </div>
        <div class="insight fix">
          <h4>Without Mbappé, France have almost no attacking threat</h4>
          <p>Sequences without Mbappé involvement average 0.014–0.058 shots per sequence across games,
          versus 0.143–0.348 with him. In the Tunisia and Argentina games, where France struggled most,
          the without-Mbappé sequences were the least productive of the tournament.
          France's attacking output is highly concentrated in one player.</p>
        </div>
        <div class="insight amb">
          <h4>Implication: neutralising Mbappé neutralises France</h4>
          <p>Morocco (0-0 until 79') and Tunisia (0-0 for whole regulation) both showed that when Mbappé
          is held without involvement, France's without-Mbappé sequences do not compensate.
          The pass network data shows France do not have a reliable alternative attacking route.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="stitle">analysis 2 — shot quality by phase</div>
      <div class="g2">
        <div class="insight fix">
          <h4>Mbappé is most lethal when chasing: 42% goal rate after conceding</h4>
          <p>After the opponent scores, Mbappé converts 42% of his shots into goals (3 goals from 7 shots).
          This is higher than after France score (25%, 4 from 16) or at game start (14%, 1 from 7).
          His individual quality actually rises under pressure; the team's problem is structural,
          not Mbappé's personal form.</p>
        </div>
        <div class="insight">
          <h4>Most shots come after France score, but conversion is lower</h4>
          <p>16 of Mbappé's 30 shots came in after-France-goal phases. Despite the volume,
          conversion was only 25% and 68% of those shots came under pressure, the highest pressed rate
          of any phase. France may be playing faster and more directly after scoring rather than
          building cleaner chances for him.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="stitle">analysis 3 — passing network</div>
      <div class="g2">
        <div class="insight">
          <h4>Tchouaméni is France's central hub: but his targeting shifts when chasing</h4>
          <p>Tchouaméni is the #1 pass distributor in all three phase types, accounting for 10–14%
          of all completed pass involvement. Critically, when France are chasing goals he targets
          Mbappé 15 times (vs 12 in game start, becoming his 2nd-most-targeted player); 
          but the Tchouaméni→Mbappé completion rate falls when the pressure is highest.</p>
        </div>
        <div class="insight fix">
          <h4>Griezmann becomes more central after France score, a tactical strength</h4>
          <p>In after-France-goal phases, Griezmann rises from 6th to 3rd in pass involvement.
          He links play more actively when France control the game. His involvement in calmer
          phases correlates with France's safest tactical periods. The network becomes
          more balanced and less Mbappé-dependent when ahead.</p>
        </div>
        <div class="insight">
          <h4>When chasing, Varane and Kounde drop in involvement, and the wide defenders recede</h4>
          <p>Varane drops from 2nd overall (game start) to 9th (after opp goal). Kounde drops
          from 5th to 8th. When France need a goal, the full-backs and centre-backs contribute less
          to build-up. France become more vertical and central, bypassing the wide defensive
          outlets. This compresses the attack and makes them more predictable.</p>
        </div>
        <div class="insight amb">
          <h4>Camavinga enters the network when chasing, a deliberate adjustment</h4>
          <p>Camavinga appears in the top 10 only in after-opponent-goal phases (4th among
          non-starters, 10th overall), reflecting his role as an impact substitute when France
          need urgency. His presence shifts the network toward more central distribution.
          Whether this is sufficiently effective is not clear from pass counts alone.</p>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
const D = {chart_data};

function showTab(n){{
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+n).classList.add('active');
  event.target.classList.add('active');
}}

const TC = {{
  plugins:{{legend:{{display:false}},tooltip:{{backgroundColor:'#1a1a1a',titleColor:'#f0f0f0',bodyColor:'#999',borderColor:'#333',borderWidth:1}}}},
  scales:{{x:{{grid:{{color:'rgba(255,255,255,0.05)'}},ticks:{{color:'#666'}}}},y:{{grid:{{color:'rgba(255,255,255,0.05)'}},ticks:{{color:'#666'}}}}}}
}};

// ── KPIs ──
const tsWS = D.total_with_shots/Math.max(D.total_with_seqs,1);
const tsWO = D.total_wo_shots/Math.max(D.total_wo_seqs,1);
const tgWS = D.total_with_goals/Math.max(D.total_with_seqs,1);
const tgWO = D.total_wo_goals/Math.max(D.total_wo_seqs,1);
const tlbW = D.lb_with.reduce((a,b)=>a+b,0)/D.n_with.reduce((a,b)=>a+b,0);
const tlbO = D.lb_without.reduce((a,b)=>a+b,0)/D.n_without.reduce((a,b)=>a+b,0);
const shotRatio = (tsWS/Math.max(tsWO,0.001)).toFixed(1);
const goalRatio = tgWO>0?(tgWS/tgWO).toFixed(1):'∞';

document.getElementById('kpi-shots-with').textContent   = tsWS.toFixed(3);
document.getElementById('kpi-shots-without').textContent= tsWO.toFixed(3);
document.getElementById('kpi-shots-ratio').textContent  = shotRatio+'× more shots per seq with Mbappé';
document.getElementById('kpi-goals-with').textContent   = tgWS.toFixed(3);
document.getElementById('kpi-goals-ratio').textContent  = goalRatio+'× vs without Mbappé';
document.getElementById('kpi-lb-with').textContent      = tlbW.toFixed(3);
document.getElementById('kpi-lb-ratio').textContent     = (tlbW/Math.max(tlbO,0.001)).toFixed(1)+'× vs without';
document.getElementById('find-shots-ratio').textContent = shotRatio;
document.getElementById('find-goals-ratio').textContent = goalRatio;

// ── Isolation ──
['open','fra','opp'].forEach((k,i)=>{{
  const pt = ['opening','after_fra','after_opp'][i];
  const d = D.isolation[pt];
  document.getElementById('iso-to-'+k).textContent = d.to_mb;
  document.getElementById('iso-to-'+k+'-pct').textContent = d.to_mb_pct+'% reached him';
  document.getElementById('iso-mb-'+k).textContent = d.mb_made;
  document.getElementById('iso-mb-'+k+'-pct').textContent = d.mb_comp_pct+'% completion';
}});

// ── Shot quality cards ──
[['open','opening'],['fra','after_fra'],['opp','after_opp']].forEach(([k,pt])=>{{
  const q=D.shot_quality[pt];
  document.getElementById('sq-'+k+'-n').textContent =q.n+' shots';
  document.getElementById('sq-'+k+'-g').textContent =q.goals+' ('+q.goal_pct+'%)';
  document.getElementById('sq-'+k+'-ot').textContent=q.on_target+' ('+q.on_tgt_pct+'%)';
  document.getElementById('sq-'+k+'-pr').textContent=q.pressed+' ('+q.pressed_pct+'%)';
}});

// ── Shot log ──
const OUTCOME_LABEL={{'G':'Goal','S':'Saved','F':'Saved','B':'Blocked','O':'Off target','C':'Off target'}};
const OUTCOME_COL={{'G':'#27ae60','S':'#3498db','F':'#3498db','B':'#f39c12','O':'#e74c3c','C':'#e74c3c'}};
const PHASE_COL={{'opening':'#888','after_fra':'#27ae60','after_opp':'#e74c3c'}};
const PHASE_LBL={{'opening':'Game start','after_fra':'After Fra goal','after_opp':'After opp goal'}};
const tbody=document.getElementById('shot-log-body');
D.all_shots.forEach(s=>{{
  const tr=document.createElement('tr');
  const oc=OUTCOME_COL[s.outcome]||'#888';
  const pc=PHASE_COL[s.phase];
  tr.innerHTML=`<td><strong>${{s.label}}</strong></td><td>${{s.fmt}}</td>
    <td><span class="badge" style="background:${{pc}}22;color:${{pc}};">${{PHASE_LBL[s.phase]}}</span></td>
    <td><span class="badge" style="background:${{oc}}22;color:${{oc}};">${{OUTCOME_LABEL[s.outcome]||s.outcome}}</span></td>
    <td>${{s.pressed?'<span class="badge b-amb">Pressed</span>':'<span class="badge b-grn">Free</span>'}}</td>`;
  tbody.appendChild(tr);
}});

