# MBAPPE INVOLVEMENT
def compute_mbappe_involvement():
    """Per-game and per-tournament: sequences with/without Mbappé involvement."""
    results = []

    for gid in GAME_ORDER:
        _, label, opp, france_home = FILE_MAP[gid]
        raw   = load_raw(gid)
        goals = get_goals(raw, gid)

        # Step 1: classify each sequence as Mbappé-involved or not
        seq_mbappe = {}
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if ge.get("teamName") != "France": continue
            seq = r.get("sequence")
            if seq is None: continue
            clock = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            involved = any([
                pe.get("passerPlayerName")    == "Kylian Mbappé",
                pe.get("receiverPlayerName")  == "Kylian Mbappé",
                pe.get("shooterPlayerName")   == "Kylian Mbappé",
                pe.get("carrierPlayerName")   == "Kylian Mbappé",
                pe.get("ballCarrierPlayerName")== "Kylian Mbappé",
                ge.get("playerName")          == "Kylian Mbappé",
            ])
            if involved:
                seq_mbappe[seq] = True
            elif seq not in seq_mbappe:
                seq_mbappe[seq] = False

        # Step 2: accumulate sequence stats
        seq_stats = defaultdict(lambda: {"shots":0,"goals":0,"C":0,"H":0,
                                          "passes":0,"comp":0,"lb":0})
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if ge.get("teamName") != "France": continue
            seq = r.get("sequence")
            if seq is None: continue
            clock = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            s = seq_stats[seq]
            s["shots"]  += (pe.get("possessionEventType") == "SH")
            s["goals"]  += (pe.get("shotOutcomeType") == "G")
            s["C"]      += (pe.get("opportunityType") == "C")
            s["H"]      += (pe.get("opportunityType") == "H")
            s["lb"]     += bool(pe.get("linesBrokenType"))
            if pe.get("possessionEventType") == "PA" and pe.get("passerPlayerName"):
                s["passes"] += 1
                s["comp"]   += (pe.get("passOutcomeType") == "C")

        def agg(seqs):
            n = len(seqs)
            if n == 0: return {}
            return {
                "n": n,
                "shots_per_seq":  round(sum(s["shots"]  for s in seqs) / n, 3),
                "goals_per_seq":  round(sum(s["goals"]  for s in seqs) / n, 3),
                "chances_per_seq":round(sum(s["C"]+s["H"] for s in seqs) / n, 3),
                "lb_per_seq":     round(sum(s["lb"]     for s in seqs) / n, 3),
                "pass_comp":      round(100 * sum(s["comp"] for s in seqs) /
                                        max(sum(s["passes"] for s in seqs), 1), 1),
                "total_shots":    sum(s["shots"] for s in seqs),
                "total_goals":    sum(s["goals"] for s in seqs),
            }

        with_m    = [seq_stats[s] for s in seq_mbappe if seq_mbappe[s] and s in seq_stats]
        without_m = [seq_stats[s] for s in seq_mbappe if not seq_mbappe[s] and s in seq_stats]

        results.append({
            "gid": gid, "label": label, "opp": opp,
            "with":    agg(with_m),
            "without": agg(without_m),
        })

    return results


def compute_mbappe_shots_by_phase():
    """All Mbappé shots labelled by phase type."""
    shots = []
    for gid in GAME_ORDER:
        _, label, opp, france_home = FILE_MAP[gid]
        raw   = load_raw(gid)
        goals = get_goals(raw, gid)
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if pe.get("shooterPlayerName") != "Kylian Mbappé": continue
            clock = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            outcome = pe.get("shotOutcomeType", "")
            shots.append({
                "gid": gid, "label": label,
                "clock": clock, "fmt": ge.get("startFormattedGameClock",""),
                "outcome": outcome,
                "on_target": outcome in ("G","S","F"),
                "is_goal":   outcome == "G",
                "pressed":   pe.get("pressureType","") in ("P","A"),
                "phase":     phase_type(clock, goals),
                "body":      pe.get("bodyType",""),
                "nature":    pe.get("shotNatureType",""),
            })
    return shots


def compute_mbappe_pass_isolation():
    """Passes aimed at Mbappé vs completions, and his own pass comp, by phase."""
    data = {pt: {"to_mb":0,"to_mb_comp":0,"mb_made":0,"mb_comp":0}
            for pt in ["opening","after_fra","after_opp"]}

    for gid in GAME_ORDER:
        _, label, opp, france_home = FILE_MAP[gid]
        raw   = load_raw(gid)
        goals = get_goals(raw, gid)
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if ge.get("teamName") != "France": continue
            if pe.get("possessionEventType") != "PA": continue
            clock = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            pt   = phase_type(clock, goals)
            comp = pe.get("passOutcomeType") == "C"
            if pe.get("passerPlayerName") == "Kylian Mbappé":
                data[pt]["mb_made"] += 1
                if comp: data[pt]["mb_comp"] += 1
            if pe.get("targetPlayerName") == "Kylian Mbappé":
                data[pt]["to_mb"] += 1
                if comp: data[pt]["to_mb_comp"] += 1

    return data



# Passing Networks
def compute_network_centrality():
    """Pass involvement (made + received) per player per phase type."""
    made     = {pt: defaultdict(int) for pt in ["opening","after_fra","after_opp"]}
    received = {pt: defaultdict(int) for pt in ["opening","after_fra","after_opp"]}
    totals   = {pt: 0 for pt in ["opening","after_fra","after_opp"]}

    for gid in GAME_ORDER:
        _, label, opp, france_home = FILE_MAP[gid]
        raw   = load_raw(gid)
        goals = get_goals(raw, gid)
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if ge.get("teamName") != "France": continue
            if pe.get("possessionEventType") != "PA": continue
            if pe.get("passOutcomeType") != "C": continue   # completed only
            clock  = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            passer   = pe.get("passerPlayerName")
            receiver = pe.get("receiverPlayerName")
            pt       = phase_type(clock, goals)
            if passer and passer in FRANCE_PLAYERS:
                p = SHORT.get(passer, passer)
                made[pt][p] += 1
                totals[pt]  += 1
            if receiver and receiver in FRANCE_PLAYERS:
                r2 = SHORT.get(receiver, receiver)
                received[pt][r2] += 1

    result = {}
    for pt in ["opening","after_fra","after_opp"]:
        all_p = set(list(made[pt].keys()) + list(received[pt].keys()))
        inv   = {p: made[pt].get(p,0) + received[pt].get(p,0) for p in all_p}
        total_passes = totals[pt]
        result[pt] = {
            "total_passes": total_passes,
            "players": [
                {"name": p,
                 "made": made[pt].get(p,0),
                 "received": received[pt].get(p,0),
                 "involvement": inv[p],
                 "pct": round(100 * inv[p] / max(total_passes * 2, 1), 1)}
                for p in sorted(inv, key=lambda x: -inv[x])[:12]
            ]
        }
    return result


def compute_tchouameni_targets():
    """Tchouaméni's top pass targets by phase: he's the #1 distributor."""
    data = {pt: defaultdict(lambda: {"total":0,"comp":0})
            for pt in ["opening","after_fra","after_opp"]}

    for gid in GAME_ORDER:
        _, label, opp, france_home = FILE_MAP[gid]
        raw   = load_raw(gid)
        goals = get_goals(raw, gid)
        for r in raw:
            ge = r.get("gameEvents") or {}
            pe = r.get("possessionEvents") or {}
            if pe.get("nonEvent"): continue
            if ge.get("teamName") != "France": continue
            if pe.get("possessionEventType") != "PA": continue
            if pe.get("passerPlayerName") != "Aurélien Tchouaméni": continue
            clock  = ge.get("startGameClock", 0) or 0
            if gid == "10517" and clock > 7200: continue
            target = pe.get("targetPlayerName")
            if not target or target not in FRANCE_PLAYERS: continue
            pt   = phase_type(clock, goals)
            comp = pe.get("passOutcomeType") == "C"
            t    = SHORT.get(target, target.split()[-1])
            data[pt][t]["total"] += 1
            if comp: data[pt][t]["comp"] += 1

    return {pt: sorted(data[pt].items(), key=lambda x: -x[1]["total"])[:7]
            for pt in data}




# HTML
def build_html(inv_data, shot_data, isolation_data, network_data, tchou_data):
    import json as _json

    # ── Involvement chart data ──
    game_labels = [FILE_MAP[g][1] for g in GAME_ORDER]
    shots_with    = [d["with"].get("shots_per_seq", 0)  for d in inv_data]
    shots_without = [d["without"].get("shots_per_seq",0) for d in inv_data]
    goals_with    = [d["with"].get("goals_per_seq", 0)  for d in inv_data]
    goals_without = [d["without"].get("goals_per_seq",0) for d in inv_data]
    lb_with       = [d["with"].get("lb_per_seq", 0)     for d in inv_data]
    lb_without    = [d["without"].get("lb_per_seq",0)    for d in inv_data]
    comp_with     = [d["with"].get("pass_comp", 0)      for d in inv_data]
    comp_without  = [d["without"].get("pass_comp",0)     for d in inv_data]
    n_with        = [d["with"].get("n", 0)               for d in inv_data]
    n_without     = [d["without"].get("n",0)              for d in inv_data]

    # Tournament totals
    total_with_shots  = sum(d["with"].get("total_shots",0)  for d in inv_data)
    total_with_goals  = sum(d["with"].get("total_goals",0)  for d in inv_data)
    total_with_seqs   = sum(d["with"].get("n",0)            for d in inv_data)
    total_wo_shots    = sum(d["without"].get("total_shots",0) for d in inv_data)
    total_wo_goals    = sum(d["without"].get("total_goals",0) for d in inv_data)
    total_wo_seqs     = sum(d["without"].get("n",0)           for d in inv_data)

    # ── Shot quality ──
    phase_shots = {pt: [s for s in shot_data if s["phase"]==pt]
                   for pt in ["opening","after_fra","after_opp"]}

    def shot_stats(lst):
        n = len(lst)
        return {
            "n": n,
            "goals":     sum(s["is_goal"]   for s in lst),
            "on_target": sum(s["on_target"] for s in lst),
            "pressed":   sum(s["pressed"]   for s in lst),
            "goal_pct":     round(100*sum(s["is_goal"]   for s in lst)/max(n,1)),
            "on_tgt_pct":   round(100*sum(s["on_target"] for s in lst)/max(n,1)),
            "pressed_pct":  round(100*sum(s["pressed"]   for s in lst)/max(n,1)),
        }

    sq = {pt: shot_stats(phase_shots[pt]) for pt in phase_shots}

    # All shots for scatter plot
    all_shots_scatter = [
        {"phase": s["phase"], "label": s["label"], "fmt": s["fmt"],
         "outcome": s["outcome"], "goal": s["is_goal"],
         "on_target": s["on_target"], "pressed": s["pressed"]}
        for s in shot_data
    ]

    # ── Pass isolation ──
    iso = {pt: {
        "to_mb":      isolation_data[pt]["to_mb"],
        "to_mb_comp": isolation_data[pt]["to_mb_comp"],
        "to_mb_pct":  round(100*isolation_data[pt]["to_mb_comp"]/max(isolation_data[pt]["to_mb"],1)),
        "mb_made":    isolation_data[pt]["mb_made"],
        "mb_comp":    isolation_data[pt]["mb_comp"],
        "mb_comp_pct":round(100*isolation_data[pt]["mb_comp"]/max(isolation_data[pt]["mb_made"],1)),
    } for pt in ["opening","after_fra","after_opp"]}

    # ── Network centrality ──
    net_json = {pt: network_data[pt] for pt in network_data}

    # ── Tchouaméni targets ──
    tchou_json = {pt: [{"name":n,"total":d["total"],"comp":d["comp"],
                         "pct": round(100*d["comp"]/max(d["total"],1))}
                        for n,d in tchou_data[pt]]
                  for pt in tchou_data}

    chart_data = _json.dumps({
        "game_labels":    game_labels,
        "shots_with":     shots_with,
        "shots_without":  shots_without,
        "goals_with":     goals_with,
        "goals_without":  goals_without,
        "lb_with":        lb_with,
        "lb_without":     lb_without,
        "comp_with":      comp_with,
        "comp_without":   comp_without,
        "n_with":         n_with,
        "n_without":      n_without,
        "total_with_shots": total_with_shots,
        "total_with_goals": total_with_goals,
        "total_with_seqs":  total_with_seqs,
        "total_wo_shots":   total_wo_shots,
        "total_wo_goals":   total_wo_goals,
        "total_wo_seqs":    total_wo_seqs,
        "shot_quality":   sq,
        "all_shots":      all_shots_scatter,
        "isolation":      iso,
        "network":        net_json,
        "tchouameni":     tchou_json,
    })

    # ── Involvement rows for table ──
    inv_rows = ""
    for d in inv_data:
        w = d["with"]; wo = d["without"]
        inv_rows += f"""
        <tr>
          <td><strong>{d['label']}</strong></td>
          <td>{w.get('n',0)}</td>
