          <td style="color:#27ae60;font-weight:600">{w.get('goals_per_seq',0):.3f}</td>
          <td style="color:#27ae60;font-weight:600">{w.get('lb_per_seq',0):.3f}</td>
          <td style="color:#27ae60;font-weight:600">{w.get('pass_comp',0):.1f}%</td>
          <td>{wo.get('n',0)}</td>
          <td style="color:#e74c3c">{wo.get('shots_per_seq',0):.3f}</td>
          <td style="color:#e74c3c">{wo.get('goals_per_seq',0):.3f}</td>
          <td style="color:#e74c3c">{wo.get('lb_per_seq',0):.3f}</td>
          <td style="color:#e74c3c">{wo.get('pass_comp',0):.1f}%</td>
        </tr>"""

    # ── KPI cards ──
    spm_ratio = round(total_with_shots/max(total_with_seqs,1) /
                      max(total_wo_shots/max(total_wo_seqs,1),0.001), 1)
    gpm_ratio = round(total_with_goals/max(total_with_seqs,1) /
                      max(total_wo_goals/max(total_wo_seqs,1),0.001), 1) if total_wo_goals else "∞"

    # Mbappé shot quality KPI narrative
    sq_open = sq["opening"]; sq_fra = sq["after_fra"]; sq_opp = sq["after_opp"]

    return f"""<!DOCTYPE html>
