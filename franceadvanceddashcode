        x:{{...TC.scales.x,ticks:{{color:'#666',font:{{size:9}}}}}},
        y:{{...TC.scales.y,ticks:{{color:'#ccc',font:{{size:10}}}}}}
      }}
    }}
  }});
}}
mkTchouChart('chartTchouOpen','opening');
mkTchouChart('chartTchouFra','after_fra');
